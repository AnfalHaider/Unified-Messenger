<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="UnifiedMessenger.Controls.ActivityPatternsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="10"
        Padding="18,16">
        <Grid RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header + account/range filters -->
            <Grid Grid.Row="0" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="2" VerticalAlignment="Center">
                    <TextBlock FontSize="15" FontWeight="SemiBold" Text="Activity patterns" />
                    <TextBlock
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="When your customers message most" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <ComboBox x:Name="AccountSelector" MinWidth="150" SelectionChanged="OnFilterChanged" />
                    <ComboBox x:Name="RangeSelector" MinWidth="130" SelectionChanged="OnFilterChanged">
                        <ComboBoxItem Content="Last 90 days" IsSelected="True" Tag="90" />
                        <ComboBoxItem Content="Last 30 days" Tag="30" />
                        <ComboBoxItem Content="This year" Tag="year" />
                        <ComboBoxItem Content="All time" Tag="all" />
                    </ComboBox>
                </StackPanel>
            </Grid>

            <!-- Dimension segmented control -->
            <Border
                Grid.Row="1"
                HorizontalAlignment="Left"
                CornerRadius="6"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                Padding="2">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <ToggleButton x:Name="HourButton" Content="Hour of day" IsChecked="True" Click="OnHourClick" Padding="12,4" CornerRadius="4" />
                    <ToggleButton x:Name="DayButton" Content="Day of week" Click="OnDayClick" Padding="12,4" CornerRadius="4" />
                    <ToggleButton x:Name="MonthButton" Content="Month" Click="OnMonthClick" Padding="12,4" CornerRadius="4" />
                    <ToggleButton x:Name="HeatmapButton" Content="Heat map" Click="OnHeatmapClick" Padding="12,4" CornerRadius="4"
                        ToolTipService.ToolTip="When are you busiest, by weekday and hour — for planning coverage" />
                </StackPanel>
            </Border>

            <!-- Chart: bars + axis labels + per-account legend (built imperatively) -->
            <StackPanel Grid.Row="2" Spacing="6">
                <StackPanel x:Name="ChartArea" Spacing="6">
                    <Grid x:Name="ChartHost" Height="190" />
                    <Grid x:Name="AxisHost" />
                    <ItemsRepeater x:Name="LegendHost" Margin="0,4,0,0">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="14" />
                        </ItemsRepeater.Layout>
                    </ItemsRepeater>
                </StackPanel>
                <Grid x:Name="HeatmapHost" Visibility="Collapsed" />
            </StackPanel>

            <!-- Insight + week-over-week trend -->
            <StackPanel Grid.Row="3" Spacing="8">
                <Border
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    CornerRadius="6"
                    Padding="11,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="15" Foreground="{ThemeResource SystemFillColorCautionBrush}" Glyph="&#xEA80;" VerticalAlignment="Center" />
                        <TextBlock x:Name="InsightText" FontSize="13" VerticalAlignment="Center" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
                <StackPanel x:Name="WeekRow" Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
                    <FontIcon FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Glyph="&#xE9D2;" VerticalAlignment="Center" />
                    <TextBlock x:Name="WeekText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" TextWrapping="WrapWholeWords" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
