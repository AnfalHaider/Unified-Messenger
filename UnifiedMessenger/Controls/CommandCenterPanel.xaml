<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="UnifiedMessenger.Controls.CommandCenterPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0 — title + primary actions -->
        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="2" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Command center" />
                <TextBlock
                    x:Name="SubtitleText"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock
                    x:Name="UpdatedText"
                    FontSize="11"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Visibility="Collapsed" />
            </StackPanel>
            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="10"
                VerticalAlignment="Center">
                <CalendarDatePicker
                    x:Name="FromDatePicker"
                    MinWidth="130"
                    DateChanged="OnCustomDateChanged"
                    PlaceholderText="From"
                    Visibility="Collapsed" />
                <CalendarDatePicker
                    x:Name="ToDatePicker"
                    MinWidth="130"
                    DateChanged="OnCustomDateChanged"
                    PlaceholderText="To"
                    Visibility="Collapsed" />
                <ComboBox
                    x:Name="WindowSelector"
                    MinWidth="120"
                    SelectionChanged="OnWindowChanged"
                    ToolTipService.ToolTip="Caught-up % is measured over conversations active in this date range">
                    <ComboBoxItem Content="Today" IsSelected="True" Tag="Today" />
                    <ComboBoxItem Content="Last 7 days" Tag="Week" />
                    <ComboBoxItem Content="All time" Tag="All" />
                    <ComboBoxItem Content="Custom range" Tag="Custom" />
                </ComboBox>
                <Button
                    x:Name="ResyncButton"
                    Click="OnResyncClick"
                    Style="{StaticResource AccentButtonStyle}"
                    ToolTipService.ToolTip="Re-read history, refresh the numbers, the activity graph, and Google reviews">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE895;" />
                        <TextBlock Text="Re-sync" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Row 1 — at-a-glance KPI summary band + AI shift briefing -->
        <StackPanel Grid.Row="1" Spacing="10">
        <Grid x:Name="KpiBand" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                CornerRadius="8"
                Padding="14,10">
                <StackPanel Spacing="1">
                    <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Caught up" />
                    <TextBlock x:Name="KpiCaughtUpValue" FontSize="24" FontWeight="SemiBold" Text="—" />
                    <TextBlock x:Name="KpiCaughtUpHint" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="across all accounts" />
                </StackPanel>
            </Border>

            <Border
                Grid.Column="1"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                CornerRadius="8"
                Padding="14,10">
                <StackPanel Spacing="1">
                    <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Awaiting reply" />
                    <TextBlock x:Name="KpiAwaitingValue" FontSize="24" FontWeight="SemiBold" Text="—" />
                    <TextBlock x:Name="KpiAwaitingHint" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="customers waiting" />
                </StackPanel>
            </Border>

            <Border
                Grid.Column="2"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                CornerRadius="8"
                Padding="14,10">
                <StackPanel Spacing="1">
                    <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Messages / day" />
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock x:Name="KpiMessagesValue" FontSize="24" FontWeight="SemiBold" Text="—" />
                        <TextBlock x:Name="KpiMessagesDelta" FontSize="11" VerticalAlignment="Bottom" Margin="0,0,0,5" />
                    </StackPanel>
                    <TextBlock x:Name="KpiMessagesHint" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="7-day average" />
                </StackPanel>
            </Border>

            <Border
                Grid.Column="3"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                CornerRadius="8"
                Padding="14,10">
                <StackPanel Spacing="1">
                    <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Busiest window" />
                    <TextBlock x:Name="KpiBusiestValue" FontSize="24" FontWeight="SemiBold" Foreground="{ThemeResource SystemFillColorCautionBrush}" Text="—" />
                    <TextBlock x:Name="KpiBusiestHint" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="peak hour" />
                </StackPanel>
            </Border>
        </Grid>

        <Border
            x:Name="BriefingStrip"
            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
            CornerRadius="8"
            Padding="12,9"
            Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock
                    x:Name="BriefingBadge"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource SystemFillColorCautionBrush}"
                    Text="✦"
                    VerticalAlignment="Top"
                    Margin="0,1,0,0" />
                <TextBlock x:Name="BriefingText" FontSize="13" TextWrapping="WrapWholeWords" VerticalAlignment="Center" />
            </StackPanel>
        </Border>
        </StackPanel>

        <!-- Row 2 — mode segmented control + filter + density -->
        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border
                CornerRadius="6"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                Padding="2"
                VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <ToggleButton
                        x:Name="GroupByAccountButton"
                        Content="By account"
                        IsChecked="True"
                        Click="OnGroupByAccountClick"
                        Padding="10,4"
                        CornerRadius="4" />
                    <ToggleButton
                        x:Name="GroupByLocationButton"
                        Content="By location"
                        IsChecked="False"
                        Click="OnGroupByLocationClick"
                        Padding="10,4"
                        CornerRadius="4" />
                    <ToggleButton
                        x:Name="NeedsReplyButton"
                        Content="Needs reply"
                        IsChecked="False"
                        Click="OnNeedsReplyClick"
                        Padding="10,4"
                        CornerRadius="4"
                        ToolTipService.ToolTip="Every customer awaiting a reply across all accounts, most urgent first" />
                </StackPanel>
            </Border>
            <AutoSuggestBox
                x:Name="SearchBox"
                Grid.Column="1"
                MaxWidth="280"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                PlaceholderText="Filter accounts or locations…"
                QueryIcon="Find"
                TextChanged="OnSearchChanged" />
            <ToggleButton
                x:Name="DensityToggle"
                Grid.Column="2"
                Click="OnDensityToggled"
                VerticalAlignment="Center"
                ToolTipService.ToolTip="Compact view — denser rows for many accounts">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE8A4;" />
                    <TextBlock Text="Compact" />
                </StackPanel>
            </ToggleButton>
        </Grid>

        <!-- Row 3 — define-locations CTA -->
        <Border
            x:Name="LocationCtaBanner"
            Grid.Row="3"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14,10"
            Visibility="Collapsed">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <FontIcon
                    VerticalAlignment="Center"
                    FontSize="16"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Glyph="&#xE707;" />
                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    FontSize="13">
                    <Run>Group accounts into&#160;</Run><Run FontWeight="SemiBold">locations</Run><Run>&#160;to oversee a whole branch at once.</Run>
                </TextBlock>
                <Button
                    x:Name="DefineLocationsButton"
                    Grid.Column="2"
                    Content="Define locations ↗"
                    Click="OnDefineLocations"
                    VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Row 4 — informational digest (since you were last here); neutral info styling, dismissible -->
        <Border
            x:Name="DigestBanner"
            Grid.Row="4"
            Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}"
            CornerRadius="8"
            Padding="12,9"
            Visibility="Collapsed">
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <FontIcon
                    VerticalAlignment="Center"
                    FontSize="16"
                    Foreground="{ThemeResource SystemFillColorAttentionBrush}"
                    Glyph="&#xE946;" />
                <TextBlock
                    x:Name="DigestText"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    TextWrapping="WrapWholeWords" />
                <Button
                    x:Name="DigestDismiss"
                    Grid.Column="2"
                    Click="OnDismissDigest"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="6"
                    VerticalAlignment="Center"
                    ToolTipService.ToolTip="Dismiss">
                    <FontIcon FontSize="12" Glyph="&#xE711;" />
                </Button>
            </Grid>
        </Border>

        <!-- Row 5 — attention banner (caution): real backlog needing action -->
        <Border
            x:Name="AttentionBanner"
            Grid.Row="5"
            Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
            CornerRadius="8"
            Padding="12,10"
            Visibility="Collapsed">
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <FontIcon
                    VerticalAlignment="Center"
                    FontSize="16"
                    Foreground="{ThemeResource SystemFillColorCautionBrush}"
                    Glyph="&#xE7BA;" />
                <TextBlock x:Name="AttentionText" Grid.Column="1" VerticalAlignment="Center" TextWrapping="WrapWholeWords" />
                <Button
                    x:Name="AttentionJumpButton"
                    Grid.Column="2"
                    Content="Jump"
                    Click="OnAttentionJump"
                    Visibility="Collapsed"
                    VerticalAlignment="Center" />
            </Grid>
        </Border>

        <StackPanel x:Name="CardsHost" Grid.Row="6" Spacing="8" />
    </Grid>
</UserControl>
