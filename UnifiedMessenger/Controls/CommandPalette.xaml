<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="UnifiedMessenger.Controls.CommandPalette"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    KeyDown="Root_KeyDown"
    mc:Ignorable="d">

    <Grid
        x:Name="Overlay"
        Background="#66000000"
        PointerPressed="Overlay_PointerPressed">
        <Border
            x:Name="PalettePanel"
            MaxWidth="560"
            Margin="24,72,24,24"
            Padding="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            AutomationProperties.AutomationId="CommandPaletteRoot"
            AutomationProperties.Name="Command palette"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12"
            PointerPressed="Panel_PointerPressed"
            TabFocusNavigation="Cycle">
            <StackPanel Spacing="0">
                <AutoSuggestBox
                    x:Name="SearchBox"
                    AutomationProperties.AutomationId="CommandPaletteSearch"
                    AutomationProperties.Name="Command Palette Search"
                    Margin="12,12,12,8"
                    PlaceholderText="Search instances, alerts, and actions..."
                    QueryIcon="Find"
                    QuerySubmitted="SearchBox_QuerySubmitted"
                    TextChanged="SearchBox_TextChanged" />

                <ListView
                    x:Name="ResultsList"
                    AutomationProperties.Name="Command palette results"
                    MaxHeight="360"
                    IsItemClickEnabled="True"
                    ItemClick="ResultsList_ItemClick"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="12,10" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Glyph="{Binding IconGlyph}"
                                    Opacity="0.55" />
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="{Binding Title}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="{Binding Subtitle}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
