<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="UnifiedMessenger.Controls.KanbanColumnBoard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:UnifiedMessenger.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shared="using:UnifiedMessenger.Controls.Shared"
    mc:Ignorable="d">

    <UserControl.Resources>
        <DataTemplate x:Key="OperationsKanbanCardTemplate" x:DataType="controls:OperationsThreadCardViewModel">
            <shared:OperationsThreadCardView
                Margin="{StaticResource UmMarginBottomSm}"
                DisplayStyle="Kanban"
                ViewModel="{Binding}" />
        </DataTemplate>
    </UserControl.Resources>

    <StackPanel Spacing="{StaticResource UmSpacingSm}">
        <InfoBar
            x:Name="CrossColumnInfoBar"
            IsClosable="True"
            IsOpen="False"
            Message="Drag cards between columns to update thread status. Within-column order is saved automatically."
            Severity="Informational"
            Title="Kanban drag" />

        <ScrollViewer
            HorizontalScrollBarVisibility="Auto"
            HorizontalScrollMode="Enabled"
            VerticalScrollBarVisibility="Disabled"
            VerticalScrollMode="Disabled">
            <Grid ColumnSpacing="{StaticResource UmSpacingSm}" Width="{StaticResource UmKanbanBoardMinWidth}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition MinWidth="{StaticResource UmKanbanColumnMinWidth}" Width="*" />
                    <ColumnDefinition MinWidth="{StaticResource UmKanbanColumnMinWidth}" Width="*" />
                    <ColumnDefinition MinWidth="{StaticResource UmKanbanColumnMinWidth}" Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    x:Name="NewColumnPanel"
                    Grid.Column="0"
                    AutomationProperties.AutomationId="OccKanbanNew"
                    AutomationProperties.Name="Kanban column: New inquiries"
                    Spacing="{StaticResource UmSpacingXs}">
                    <TextBlock
                        MinWidth="0"
                        Style="{StaticResource UmKanbanColumnHeaderStyle}"
                        Text="New"
                        TextTrimming="CharacterEllipsis" />
                    <Border
                        x:Name="NewColumnDropZone"
                        AllowDrop="True"
                        DragOver="DropZone_DragOver"
                        Drop="DropZone_Drop"
                        Style="{StaticResource KanbanColumnDropZoneStyle}">
                        <Grid>
                            <ItemsRepeater
                                x:Name="NewInquiriesList"
                                AutomationProperties.Name="New inquiries kanban list"
                                ItemTemplate="{StaticResource OperationsKanbanCardTemplate}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Vertical" Spacing="8" />
                                </ItemsRepeater.Layout>
                            </ItemsRepeater>
                            <Border
                                x:Name="NewInquiriesEmptyPanel"
                                Style="{StaticResource UmKanbanEmptyStateStyle}"
                                Visibility="Collapsed">
                                <StackPanel HorizontalAlignment="Center" Spacing="{StaticResource UmSpacingXs}">
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        FontSize="{StaticResource UmIconSizeSm}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Glyph="&#xE8BD;" />
                                    <TextBlock
                                        x:Name="NewInquiriesEmptyText"
                                        Style="{StaticResource UmEmptyHintTextStyle}"
                                        Text="No new inquiries." />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel
                    x:Name="HangingColumnPanel"
                    Grid.Column="1"
                    AutomationProperties.AutomationId="OccKanbanHanging"
                    AutomationProperties.Name="Kanban column: Hanging leads"
                    Spacing="{StaticResource UmSpacingXs}">
                    <TextBlock
                        MinWidth="0"
                        Style="{StaticResource UmKanbanColumnHeaderStyle}"
                        Text="Hanging"
                        TextTrimming="CharacterEllipsis" />
                    <Border
                        x:Name="HangingColumnDropZone"
                        AllowDrop="True"
                        DragOver="DropZone_DragOver"
                        Drop="DropZone_Drop"
                        Style="{StaticResource KanbanColumnDropZoneStyle}">
                        <Grid>
                            <ItemsRepeater
                                x:Name="HangingLeadsList"
                                AutomationProperties.Name="Hanging leads kanban list"
                                ItemTemplate="{StaticResource OperationsKanbanCardTemplate}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Vertical" Spacing="8" />
                                </ItemsRepeater.Layout>
                            </ItemsRepeater>
                            <Border
                                x:Name="HangingLeadsEmptyPanel"
                                Style="{StaticResource UmKanbanEmptyStateStyle}"
                                Visibility="Collapsed">
                                <StackPanel HorizontalAlignment="Center" Spacing="{StaticResource UmSpacingXs}">
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        FontSize="{StaticResource UmIconSizeSm}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Glyph="&#xE823;" />
                                    <TextBlock
                                        x:Name="HangingLeadsEmptyText"
                                        Style="{StaticResource UmEmptyHintTextStyle}"
                                        Text="No hanging leads." />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel
                    x:Name="ResolvedColumnPanel"
                    Grid.Column="2"
                    AutomationProperties.AutomationId="OccKanbanResolved"
                    AutomationProperties.Name="Kanban column: Resolved threads"
                    Spacing="{StaticResource UmSpacingXs}">
                    <TextBlock
                        MinWidth="0"
                        Style="{StaticResource UmKanbanColumnHeaderStyle}"
                        Text="Resolved"
                        TextTrimming="CharacterEllipsis" />
                    <Border
                        x:Name="ResolvedColumnDropZone"
                        AllowDrop="True"
                        DragOver="DropZone_DragOver"
                        Drop="DropZone_Drop"
                        Style="{StaticResource KanbanColumnDropZoneStyle}">
                        <Grid>
                            <ItemsRepeater
                                x:Name="ResolvedList"
                                AutomationProperties.Name="Resolved threads kanban list"
                                ItemTemplate="{StaticResource OperationsKanbanCardTemplate}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Vertical" Spacing="8" />
                                </ItemsRepeater.Layout>
                            </ItemsRepeater>
                            <Border
                                x:Name="ResolvedEmptyPanel"
                                Style="{StaticResource UmKanbanEmptyStateStyle}"
                                Visibility="Collapsed">
                                <StackPanel HorizontalAlignment="Center" Spacing="{StaticResource UmSpacingXs}">
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        FontSize="{StaticResource UmIconSizeSm}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Glyph="&#xE73E;" />
                                    <TextBlock
                                        x:Name="ResolvedEmptyText"
                                        Style="{StaticResource UmEmptyHintTextStyle}"
                                        Text="Nothing resolved yet." />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </StackPanel>
</UserControl>
