<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="UnifiedMessenger.Controls.KanbanColumnBoard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:UnifiedMessenger.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shared="using:UnifiedMessenger.Controls.Shared"
    mc:Ignorable="d">

    <UserControl.Resources>
        <DataTemplate x:Key="OperationsKanbanCardTemplate" x:DataType="controls:OperationsThreadCardViewModel">
            <shared:OperationsThreadCardView
                Margin="0,0,0,6"
                DisplayStyle="Kanban"
                ViewModel="{Binding}" />
        </DataTemplate>
    </UserControl.Resources>

    <StackPanel Spacing="8">
        <InfoBar
            x:Name="CrossColumnInfoBar"
            IsClosable="True"
            IsOpen="False"
            Message="Column placement is determined by thread status. Reorder within a column, or open the thread to update status in the platform."
            Severity="Informational"
            Title="Visual order only" />

        <Grid ColumnSpacing="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel x:Name="NewColumnPanel" Grid.Column="0" Spacing="4">
                <TextBlock FontSize="11" FontWeight="SemiBold" Text="New" />
                <Border
                    x:Name="NewColumnDropZone"
                    MinHeight="120"
                    Padding="2"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <ListView
                        x:Name="NewInquiriesList"
                        AllowDrop="True"
                        CanDragItems="False"
                        CanReorderItems="False"
                        DragItemsCompleted="KanbanList_DragItemsCompleted"
                        DragItemsStarting="KanbanList_DragItemsStarting"
                        DragOver="KanbanList_DragOver"
                        Drop="KanbanList_Drop"
                        IsItemClickEnabled="True"
                        IsSwipeEnabled="False"
                        ItemClick="KanbanList_ItemClick"
                        ItemTemplate="{StaticResource OperationsKanbanCardTemplate}"
                        RightTapped="KanbanList_RightTapped"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                        SelectionMode="None" />
                </Border>
                <TextBlock
                    x:Name="NewInquiriesEmptyText"
                    FontSize="10"
                    Opacity="0.55"
                    Text="No new inquiries."
                    Visibility="Collapsed" />
            </StackPanel>

            <StackPanel x:Name="HangingColumnPanel" Grid.Column="1" Spacing="4">
                <TextBlock FontSize="11" FontWeight="SemiBold" Text="Hanging" />
                <Border
                    x:Name="HangingColumnDropZone"
                    MinHeight="120"
                    Padding="2"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <ListView
                        x:Name="HangingLeadsList"
                        AllowDrop="True"
                        CanDragItems="False"
                        CanReorderItems="False"
                        DragItemsCompleted="KanbanList_DragItemsCompleted"
                        DragItemsStarting="KanbanList_DragItemsStarting"
                        DragOver="KanbanList_DragOver"
                        Drop="KanbanList_Drop"
                        IsItemClickEnabled="True"
                        IsSwipeEnabled="False"
                        ItemClick="KanbanList_ItemClick"
                        ItemTemplate="{StaticResource OperationsKanbanCardTemplate}"
                        RightTapped="KanbanList_RightTapped"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                        SelectionMode="None" />
                </Border>
                <TextBlock
                    x:Name="HangingLeadsEmptyText"
                    FontSize="10"
                    Opacity="0.55"
                    Text="No hanging leads."
                    Visibility="Collapsed" />
            </StackPanel>

            <StackPanel x:Name="ResolvedColumnPanel" Grid.Column="2" Spacing="4">
                <TextBlock FontSize="11" FontWeight="SemiBold" Text="Resolved" />
                <Border
                    x:Name="ResolvedColumnDropZone"
                    MinHeight="120"
                    Padding="2"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <ListView
                        x:Name="ResolvedList"
                        AllowDrop="True"
                        CanDragItems="False"
                        CanReorderItems="False"
                        DragItemsCompleted="KanbanList_DragItemsCompleted"
                        DragItemsStarting="KanbanList_DragItemsStarting"
                        DragOver="KanbanList_DragOver"
                        Drop="KanbanList_Drop"
                        IsItemClickEnabled="True"
                        IsSwipeEnabled="False"
                        ItemClick="KanbanList_ItemClick"
                        ItemTemplate="{StaticResource OperationsKanbanCardTemplate}"
                        RightTapped="KanbanList_RightTapped"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                        SelectionMode="None" />
                </Border>
                <TextBlock
                    x:Name="ResolvedEmptyText"
                    FontSize="10"
                    Opacity="0.55"
                    Text="Nothing resolved yet."
                    Visibility="Collapsed" />
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>
