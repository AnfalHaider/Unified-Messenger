<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="UnifiedMessenger.Controls.MessageVolumeLineChart"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shared="using:UnifiedMessenger.Controls.Shared"
    AutomationProperties.Name="Message volume trend"
    mc:Ignorable="d">

    <shared:SurfaceCard>
        <shared:SurfaceCard.CardBody>
            <StackPanel Spacing="{StaticResource UmSpacingMd}">
                <TextBlock
                    Style="{StaticResource UmSectionLabelTextStyle}"
                    Text="MESSAGE VOLUME" />
                <TextBlock
                    x:Name="SummaryTextBlock"
                    Opacity="0.75"
                    Style="{StaticResource UmBodyTextStyle}"
                    Text="No message volume in the selected range."
                    TextWrapping="WrapWholeWords" />
                <Grid
                    x:Name="ChartPlotGrid"
                    MinWidth="200"
                    Height="{StaticResource UmChartHeight}">
                    <Path
                        x:Name="AreaPath"
                        Fill="{StaticResource UmBrandTealBrush}"
                        Opacity="0.15"
                        Stretch="None" />
                    <Path
                        x:Name="LinePath"
                        Stroke="{StaticResource UmBrandTealBrush}"
                        StrokeThickness="2"
                        Stretch="None" />
                    <TextBlock
                        x:Name="EmptyHintText"
                        HorizontalAlignment="Center"
                        Style="{StaticResource UmEmptyHintTextStyle}"
                        Text="Activity will appear after WhatsApp messages are detected."
                        VerticalAlignment="Center"
                        Visibility="Visible" />
                </Grid>
            </StackPanel>
        </shared:SurfaceCard.CardBody>
    </shared:SurfaceCard>
</UserControl>
