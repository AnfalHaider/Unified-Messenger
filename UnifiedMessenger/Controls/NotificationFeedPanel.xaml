<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="UnifiedMessenger.Controls.NotificationFeedPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:UnifiedMessenger.Controls"
    xmlns:shared="using:UnifiedMessenger.Controls.Shared"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    AutomationProperties.AutomationId="NotificationFeedPanel"
    AutomationProperties.Name="Notification feed"
    Width="320"
    mc:Ignorable="d">

    <UserControl.Resources>
        <controls:NotificationFeedTemplateSelector x:Key="FeedTemplateSelector">
            <controls:NotificationFeedTemplateSelector.HeaderTemplate>
                <DataTemplate>
                    <Grid
                        Margin="0,14,0,6"
                        Padding="2,0"
                        ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <!-- Per-account avatar: accent circle + initials so each section is instantly identifiable -->
                        <Grid Width="22" Height="22" VerticalAlignment="Center">
                            <Ellipse Fill="{Binding AccentBrush}" />
                            <TextBlock
                                Text="{Binding GroupInitials}"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="White"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            TextTrimming="CharacterEllipsis"
                            Text="{Binding GroupTitle}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Style="{StaticResource UmSectionLabelTextStyle}" Opacity="0.55"
                            Text="{Binding GroupUnreadLabel}" />
                    </Grid>
                </DataTemplate>
            </controls:NotificationFeedTemplateSelector.HeaderTemplate>
            <controls:NotificationFeedTemplateSelector.AlertTemplate>
                <DataTemplate>
                    <Grid
                        Margin="0,0,0,8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Opacity="{Binding CardOpacity}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Background="{Binding AccentBrush}"
                            CornerRadius="8,0,0,8" />

                        <Grid
                            Grid.Column="1"
                            Padding="10,10"
                            ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Account identity line: dot + account name + time, so each row is attributable -->
                            <Grid ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="7" Height="7" VerticalAlignment="Center" Fill="{Binding AccentBrush}" />
                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Opacity="0.7"
                                    TextTrimming="CharacterEllipsis"
                                    Text="{Binding AccountName}" />
                                <TextBlock
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource UmSectionLabelTextStyle}" Opacity="0.5"
                                    Text="{Binding RelativeTimeText}" />
                            </Grid>

                            <TextBlock
                                Grid.Row="1"
                                Margin="0,3,0,0"
                                FontWeight="SemiBold"
                                Opacity="{Binding TitleOpacity}"
                                Text="{Binding Title}"
                                TextTrimming="CharacterEllipsis" />

                            <TextBlock
                                Grid.Row="2"
                                Margin="0,2,0,0"
                                Opacity="{Binding BodyOpacity}"
                                Text="{Binding Body}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="WrapWholeWords" />

                            <Button
                                Grid.RowSpan="3"
                                Grid.Column="1"
                                Margin="4,0,0,0"
                                VerticalAlignment="Top"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="DismissAlertButton_Click"
                                Tag="{Binding AlertId}"
                                ToolTipService.ToolTip="Dismiss">
                                <FontIcon FontSize="{StaticResource UmFontSizeCaption}" Glyph="&#xE711;" Opacity="0.6" />
                            </Button>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </controls:NotificationFeedTemplateSelector.AlertTemplate>
        </controls:NotificationFeedTemplateSelector>
    </UserControl.Resources>

    <Grid Background="{ThemeResource LayerFillColorDefaultBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Padding="16,12"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <InfoBadge
                    x:Name="HeaderBadge"
                    VerticalAlignment="Center"
                    Visibility="Collapsed" />
                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    AutomationProperties.Name="Notifications"
                    FontWeight="SemiBold"
                    Text="Notifications" />
                <Button
                    x:Name="MarkAllReadButton"
                    Grid.Column="2"
                    AutomationProperties.Name="Mark all notifications as read"
                    Click="MarkAllReadButton_Click"
                    ToolTipService.ToolTip="Mark all as read">
                    <FontIcon FontSize="{StaticResource UmFontSizeBody}" Glyph="&#xE930;" />
                </Button>
                <Button
                    x:Name="ClearAllButton"
                    Grid.Column="3"
                    AutomationProperties.Name="Clear all notifications"
                    Click="ClearAllButton_Click"
                    ToolTipService.ToolTip="Clear all">
                    <FontIcon FontSize="{StaticResource UmFontSizeBody}" Glyph="&#xE894;" />
                </Button>
                <Button
                    Grid.Column="4"
                    AutomationProperties.Name="Collapse notification panel"
                    Click="CollapseButton_Click"
                    ToolTipService.ToolTip="Collapse panel">
                    <FontIcon FontSize="{StaticResource UmFontSizeBody}" Glyph="&#xE76C;" />
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <ListView
                x:Name="AlertsList"
                Padding="8,0"
                AutomationProperties.Name="Notification alerts list"
                IsItemClickEnabled="True"
                ItemClick="AlertsList_ItemClick"
                ItemTemplateSelector="{StaticResource FeedTemplateSelector}"
                SelectionMode="None"
                Visibility="Collapsed">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>

            <shared:EmptyStateView
                x:Name="EmptyStatePanel"
                VerticalAlignment="Center"
                Hint="Unread badges appear on sidebar icons. Message previews show here when intercepted."
                IconGlyph="&#xEA8F;"
                Title="No notifications yet." />
        </Grid>
    </Grid>
</UserControl>
