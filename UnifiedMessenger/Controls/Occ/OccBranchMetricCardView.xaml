<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="UnifiedMessenger.Controls.Occ.OccBranchMetricCardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UnifiedMessenger.Controls.Occ"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:DefaultBindMode="OneWay"
    mc:Ignorable="d">

    <Border
        Width="168"
        MinHeight="108"
        Padding="12"
        Background="{x:Bind ViewModel.CardBackgroundBrush}"
        BorderBrush="{x:Bind ViewModel.LatencyBorderBrush}"
        BorderThickness="{x:Bind ViewModel.CardBorderThickness}"
        CornerRadius="{StaticResource UmCornerRadiusMd}"
        Opacity="{x:Bind ViewModel.CardOpacity}"
        ToolTipService.ToolTip="{x:Bind ViewModel.ToolTipText}">
        <StackPanel Spacing="4">
            <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind ViewModel.BranchName}" TextTrimming="CharacterEllipsis" />
            <TextBlock FontSize="18" FontWeight="Bold" Foreground="{x:Bind ViewModel.LatencyBrush}" Text="{x:Bind ViewModel.LatencyDisplay}" />
            <TextBlock FontSize="10" Opacity="0.75" Text="{x:Bind ViewModel.DetailDisplay}" TextWrapping="WrapWholeWords" />
            <TextBlock
                FontSize="10"
                Opacity="0.55"
                Text="{x:Bind ViewModel.PlatformBreakdown}"
                TextWrapping="WrapWholeWords"
                Visibility="{x:Bind ViewModel.PlatformBreakdownVisibility}" />
            <TextBlock
                FontSize="10"
                Opacity="0.45"
                Text="{x:Bind ViewModel.ScopeHintText}"
                Visibility="{x:Bind ViewModel.ScopeHintVisibility}" />
        </StackPanel>
    </Border>
</UserControl>
