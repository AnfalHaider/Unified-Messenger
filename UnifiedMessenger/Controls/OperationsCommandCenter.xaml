<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="UnifiedMessenger.Controls.OperationsCommandCenter"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:UnifiedMessenger.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shared="using:UnifiedMessenger.Controls.Shared"
    mc:Ignorable="d">

    <UserControl.Resources>
        <DataTemplate x:Key="OperationsImmediateCardTemplate" x:DataType="controls:OperationsThreadCardViewModel">
            <shared:OperationsThreadCardView
                Margin="0,0,0,8"
                DisplayStyle="Immediate"
                ViewModel="{Binding}" />
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <StackPanel
            x:Name="EmptyStatePanel"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="12"
            Visibility="Collapsed">
            <TextBlock
                HorizontalAlignment="Center"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="No professional accounts yet" />
            <TextBlock
                MaxWidth="420"
                HorizontalAlignment="Center"
                Opacity="0.7"
                Text="Add a WhatsApp instance with Workspace set to Professional."
                TextAlignment="Center"
                TextWrapping="WrapWholeWords" />
            <Button
                HorizontalAlignment="Center"
                Click="AddProfessionalInstanceButton_Click"
                Content="Add instance" />
        </StackPanel>

        <ScrollViewer x:Name="MainContentScrollViewer" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16" Padding="0,0,0,24">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel MinWidth="0" Spacing="4">
                        <TextBlock
                            x:Name="ScopeText"
                            MinWidth="0"
                            FontSize="14"
                            Opacity="0.9"
                            Text="Showing: All Branches"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            x:Name="LastRefreshedText"
                            MinWidth="0"
                            Style="{StaticResource UmCaptionTextStyle}"
                            Text="Updated just now"
                            TextTrimming="CharacterEllipsis" />
                        <StackPanel
                            x:Name="BranchFilterChipPanel"
                            Orientation="Horizontal"
                            Spacing="8"
                            Visibility="Collapsed">
                            <TextBlock
                                x:Name="BranchFilterChipText"
                                VerticalAlignment="Center"
                                Opacity="0.8"
                                Text="Branch filter" />
                            <Button
                                Click="ClearBranchFilterButton_Click"
                                Content="Clear"
                                Style="{StaticResource SubtleButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                    <Button
                        x:Name="RefreshCommandButton"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Click="RefreshCommandButton_Click"
                        Content="Refresh"
                        Style="{StaticResource SubtleButtonStyle}" />
                </Grid>

                <controls:BranchWorkspacePillBar x:Name="BranchWorkspacePillBar" />

                <StackPanel
                    x:Name="DateRangeFilterPanel"
                    Spacing="8">
                    <TextBlock Style="{StaticResource UmSectionLabelTextStyle}" Text="DATE RANGE" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="140" />
                            <ColumnDefinition Width="*" MinWidth="140" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <DatePicker
                            x:Name="FromDatePicker"
                            Grid.Column="0"
                            AutomationProperties.Name="From date"
                            DateChanged="DateRangePicker_DateChanged"
                            Header="From" />
                        <DatePicker
                            x:Name="ToDatePicker"
                            Grid.Column="1"
                            AutomationProperties.Name="To date"
                            DateChanged="DateRangePicker_DateChanged"
                            Header="To" />
                        <Button
                            Grid.Column="2"
                            VerticalAlignment="Bottom"
                            Click="ClearDateRangeButton_Click"
                            Content="Clear range"
                            Style="{StaticResource SubtleButtonStyle}" />
                    </Grid>
                </StackPanel>

                <Grid
                    x:Name="KpiMetricsGrid"
                    ColumnSpacing="12"
                    RowSpacing="12">
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup>
                            <VisualState x:Name="WideKpiLayout">
                                <VisualState.StateTriggers>
                                    <AdaptiveTrigger MinWindowWidth="900" />
                                </VisualState.StateTriggers>
                                <VisualState.Setters>
                                    <Setter Target="ImmediateActionCard.(Grid.Column)" Value="2" />
                                    <Setter Target="ImmediateActionCard.(Grid.Row)" Value="0" />
                                    <Setter Target="SlaBreachesCard.(Grid.Column)" Value="3" />
                                    <Setter Target="SlaBreachesCard.(Grid.Row)" Value="0" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="120" />
                        <ColumnDefinition Width="*" MinWidth="120" />
                        <ColumnDefinition Width="*" MinWidth="120" />
                        <ColumnDefinition Width="*" MinWidth="120" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <shared:MetricCardView
                        x:Name="OpenThreadsCard"
                        Grid.Column="0"
                        Grid.Row="0"
                        Label="Open threads"
                        Value="0" />
                    <shared:MetricCardView
                        x:Name="HangingLeadsCard"
                        Grid.Column="1"
                        Grid.Row="0"
                        Label="Hanging leads"
                        Value="0" />
                    <shared:MetricCardView
                        x:Name="ImmediateActionCard"
                        Grid.Column="0"
                        Grid.Row="1"
                        Label="Needs action"
                        Value="0" />
                    <shared:MetricCardView
                        x:Name="SlaBreachesCard"
                        Grid.Column="1"
                        Grid.Row="1"
                        Label="SLA breaches"
                        Value="—" />
                </Grid>

                <controls:MessageVolumeLineChart x:Name="MessageVolumeChart" />

                <StackPanel x:Name="ImmediateLaneSection" Spacing="8">
                    <TextBlock Style="{StaticResource UmSectionLabelTextStyle}" Text="Immediate queue" />
                                    <TextBlock
                        x:Name="ImmediateQueueEmptyText"
                        Opacity="0.65"
                        Text="No urgent threads in the current scope."
                                        Visibility="Collapsed" />
                                <ListView
                                    x:Name="ImmediateQueueList"
                                    IsItemClickEnabled="True"
                                    ItemClick="ThreadCardList_ItemClick"
                                    ItemTemplate="{StaticResource OperationsImmediateCardTemplate}"
                                    SelectionMode="None" />
                                </StackPanel>

                                <controls:KanbanColumnBoard
                                    x:Name="KanbanBoard"
                                    ColumnOrderChanged="KanbanBoard_ColumnOrderChanged"
                                    CrossColumnDragAttempted="KanbanBoard_CrossColumnDragAttempted"
                    ItemClickRequested="KanbanBoard_ItemClickRequested" />
                                </StackPanel>
        </ScrollViewer>

        <Grid
            x:Name="WorkspaceLoadingOverlay"
            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
            Visibility="Collapsed">
            <ProgressRing
                Width="48"
                Height="48"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsActive="True" />
        </Grid>
    </Grid>
</UserControl>
