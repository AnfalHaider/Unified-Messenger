<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="UnifiedMessenger.Controls.OperationsCommandCenter"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:UnifiedMessenger.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shared="using:UnifiedMessenger.Controls.Shared"
    mc:Ignorable="d">

    <UserControl.Resources>
        <DataTemplate x:Key="OperationsWorkQueueCardTemplate" x:DataType="controls:OperationsThreadCardViewModel">
            <shared:OperationsThreadCardView
                Margin="{StaticResource UmMarginBottomSm}"
                DisplayStyle="Immediate"
                ViewModel="{Binding}" />
        </DataTemplate>
        <DataTemplate x:Key="OperationsImmediateCardTemplate" x:DataType="controls:OperationsThreadCardViewModel">
            <shared:OperationsThreadCardView
                Margin="{StaticResource UmMarginBottomSm}"
                DisplayStyle="Immediate"
                ViewModel="{Binding}" />
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <StackPanel
            x:Name="EmptyStatePanel"
            HorizontalAlignment="Center"
            Spacing="{StaticResource UmSpacingMd}"
            VerticalAlignment="Center"
            Visibility="Collapsed">
            <TextBlock
                HorizontalAlignment="Center"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="No professional accounts yet" />
            <TextBlock
                MaxWidth="420"
                HorizontalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Add a WhatsApp instance with Workspace set to Professional."
                TextAlignment="Center"
                TextWrapping="WrapWholeWords" />
            <Button
                HorizontalAlignment="Center"
                Click="AddProfessionalInstanceButton_Click"
                Content="Add instance" />
        </StackPanel>

        <Grid x:Name="MainContentRoot" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel
                x:Name="StickyOccHeader"
                Grid.Row="0"
                Padding="{StaticResource UmPaddingBottomSm}"
                Spacing="{StaticResource UmSpacingMd}">
                <Grid ColumnSpacing="{StaticResource UmSpacingMd}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="0" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel MinWidth="0" Spacing="{StaticResource UmSpacingXs}">
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="{StaticResource UmSpacingSm}"
                            VerticalAlignment="Center">
                            <TextBlock
                                x:Name="ScopeText"
                                MinWidth="0"
                                Style="{StaticResource UmScopeTextStyle}"
                                Text="Showing: All Branches" />
                            <Border
                                x:Name="AiStatusChipPanel"
                                Padding="8,2"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                CornerRadius="{StaticResource UmCornerRadiusSmValue}"
                                Visibility="Collapsed">
                                <TextBlock
                                    x:Name="AiStatusChipText"
                                    MaxWidth="96"
                                    FontSize="{StaticResource UmBadgeFontSize}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="AI offline"
                                    TextTrimming="CharacterEllipsis" />
                            </Border>
                        </StackPanel>
                        <InfoBar
                            x:Name="NavigationStatusInfoBar"
                            IsClosable="True"
                            IsOpen="False"
                            Severity="Error"
                            Title="Navigation"
                            Closed="NavigationStatusInfoBar_Closed" />
                        <StackPanel
                            x:Name="BranchFilterChipPanel"
                            Orientation="Horizontal"
                            Spacing="{StaticResource UmSpacingSm}"
                            Visibility="Collapsed">
                            <TextBlock
                                x:Name="BranchFilterChipText"
                                MinWidth="0"
                                Style="{StaticResource UmBodyTextStyle}"
                                Text="Branch filter"
                                VerticalAlignment="Center" />
                            <Button
                                Click="ClearBranchFilterButton_Click"
                                Content="Clear"
                                Style="{StaticResource SubtleButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                    <Button
                        x:Name="RefreshCommandButton"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Click="RefreshCommandButton_Click"
                        Content="Refresh"
                        Style="{StaticResource SubtleButtonStyle}" />
                </Grid>

                <controls:BranchWorkspacePillBar x:Name="BranchWorkspacePillBar" />

                <InfoBar
                    x:Name="HistoricalDataBanner"
                    IsClosable="False"
                    IsOpen="False"
                    Severity="Informational"
                    Title="Historical report" />
                <StackPanel
                    x:Name="HistoricalActionButtons"
                    Orientation="Horizontal"
                    Spacing="{StaticResource UmSpacingSm}"
                    Visibility="Collapsed">
                    <Button
                        x:Name="SyncRecentHistoryButton"
                        Click="SyncRecentHistoryButton_Click"
                        Content="Sync recent history"
                        Style="{StaticResource SubtleButtonStyle}" />
                    <Button
                        x:Name="ReloadSnapshotButton"
                        Click="ReloadSnapshotButton_Click"
                        Content="Reload snapshot"
                        Style="{StaticResource SubtleButtonStyle}" />
                </StackPanel>

                <shared:SurfaceCard>
                    <shared:SurfaceCard.CardBody>
                        <StackPanel Spacing="{StaticResource UmSpacingMd}">
                            <Grid ColumnSpacing="{StaticResource UmSpacingMd}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition MinWidth="0" Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Style="{StaticResource UmSectionLabelTextStyle}"
                                    Text="DATE RANGE" />
                                <ToggleSwitch
                                    x:Name="OccViewModeToggle"
                                    Grid.Column="1"
                                    AutomationProperties.Name="Operations view mode"
                                    OffContent="Live workload"
                                    OnContent="Historical report"
                                    Toggled="OccViewModeToggle_Toggled"
                                    VerticalAlignment="Center" />
                            </Grid>
                            <TextBlock
                                x:Name="DateRangeScopeCaption"
                                Style="{StaticResource UmCaptionTextStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Chart uses the date range. Toggle above switches KPI and queue scope."
                                TextWrapping="WrapWholeWords" />
                            <Grid ColumnSpacing="{StaticResource UmSpacingMd}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition MinWidth="0" Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    Style="{StaticResource UmCaptionTextStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextWrapping="WrapWholeWords" />
                                <Button
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Click="ClearDateRangeButton_Click"
                                    Content="Clear Filter"
                                    Style="{StaticResource SubtleButtonStyle}" />
                            </Grid>
                            <Grid ColumnSpacing="{StaticResource UmSpacingMd}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition MinWidth="140" Width="*" />
                                    <ColumnDefinition MinWidth="140" Width="*" />
                                </Grid.ColumnDefinitions>
                                <DatePicker
                                    x:Name="FromDatePicker"
                                    Grid.Column="0"
                                    AutomationProperties.Name="From date"
                                    DateChanged="DateRangePicker_DateChanged"
                                    Header="From" />
                                <DatePicker
                                    x:Name="ToDatePicker"
                                    Grid.Column="1"
                                    AutomationProperties.Name="To date"
                                    DateChanged="DateRangePicker_DateChanged"
                                    Header="To" />
                            </Grid>
                            <controls:MessageVolumeLineChart x:Name="MessageVolumeChart" />
                        </StackPanel>
                    </shared:SurfaceCard.CardBody>
                </shared:SurfaceCard>

                <ScrollViewer
                    HorizontalScrollBarVisibility="Auto"
                    HorizontalScrollMode="Enabled"
                    VerticalScrollBarVisibility="Disabled"
                    VerticalScrollMode="Disabled">
                    <StackPanel
                        x:Name="KpiMetricsRow"
                        Orientation="Horizontal"
                        Spacing="{StaticResource UmSpacingMd}">
                        <shared:MetricCardView
                            x:Name="OpenThreadsCard"
                            MinWidth="140"
                            Width="180"
                            Activated="OpenThreadsCard_Activated"
                            IconGlyph="&#xE8BD;"
                            IsInteractive="True"
                            Label="Open threads"
                            MetricAutomationId="OccKpiOpenThreads"
                            NavigationTooltip="Open the highest-latency unreplied thread"
                            Value="0" />
                        <shared:MetricCardView
                            x:Name="UrgentCard"
                            MinWidth="140"
                            Width="180"
                            Activated="UrgentCard_Activated"
                            IconGlyph="&#xE7BA;"
                            IsInteractive="True"
                            Label="Urgent"
                            MetricAutomationId="OccKpiUrgent"
                            NavigationTooltip="Open the top urgent thread (excludes SLA-only)"
                            Value="0" />
                        <shared:MetricCardView
                            x:Name="SlaBreachesCard"
                            MinWidth="140"
                            Width="180"
                            Activated="SlaBreachesCard_Activated"
                            IconGlyph="&#xE783;"
                            IsInteractive="True"
                            Label="SLA breaches"
                            MetricAutomationId="OccKpiSlaBreaches"
                            NavigationTooltip="Open the worst SLA breach by wait time"
                            Value="0" />
                        <shared:MetricCardView
                            x:Name="HangingLeadsCard"
                            MinWidth="140"
                            Width="180"
                            Activated="HangingLeadsCard_Activated"
                            IconGlyph="&#xE823;"
                            IsInteractive="True"
                            Label="Hanging leads"
                            MetricAutomationId="OccKpiHangingLeads"
                            NavigationTooltip="Open the top hanging-lead thread"
                            Value="0" />
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Orientation="Horizontal" Spacing="{StaticResource UmSpacingSm}">
                    <ToggleButton
                        x:Name="FilterAllOpenChip"
                        Checked="QueueFilterChip_Checked"
                        Content="All open"
                        IsChecked="True"
                        Padding="10,4" />
                    <ToggleButton
                        x:Name="FilterUrgentChip"
                        Checked="QueueFilterChip_Checked"
                        Content="Urgent"
                        Padding="10,4" />
                    <ToggleButton
                        x:Name="FilterSlaChip"
                        Checked="QueueFilterChip_Checked"
                        Content="SLA"
                        Padding="10,4" />
                    <ToggleButton
                        x:Name="FilterHangingChip"
                        Checked="QueueFilterChip_Checked"
                        Content="Hanging"
                        Padding="10,4" />
                    <ToggleButton
                        x:Name="BoardViewToggle"
                        Checked="BoardViewToggle_Changed"
                        Content="Board view"
                        Padding="10,4"
                        Unchecked="BoardViewToggle_Changed" />
                </StackPanel>
            </StackPanel>

            <ScrollViewer
                x:Name="MainContentScrollViewer"
                Grid.Row="1"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Padding="{StaticResource UmPaddingBottomXl}" Spacing="{StaticResource UmSpacingLg}">
                    <StackPanel x:Name="WorkQueueSection" Spacing="{StaticResource UmSpacingSm}">
                        <TextBlock Style="{StaticResource UmSectionLabelTextStyle}" Text="Work queue" />
                        <TextBlock
                            x:Name="WorkQueueEmptyText"
                            Style="{StaticResource UmEmptyHintTextStyle}"
                            Text="No open threads in the current scope."
                            TextAlignment="Left"
                            Visibility="Collapsed" />
                        <ListView
                            x:Name="WorkQueueList"
                            AutomationProperties.AutomationId="WorkQueueList"
                            AutomationProperties.Name="Operations work queue"
                            IsItemClickEnabled="True"
                            ItemClick="ThreadCardList_ItemClick"
                            ItemTemplate="{StaticResource OperationsWorkQueueCardTemplate}"
                            SelectionMode="None"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            ScrollViewer.VerticalScrollBarVisibility="Disabled" />
                    </StackPanel>

                    <StackPanel x:Name="ImmediateLaneSection" Spacing="{StaticResource UmSpacingSm}" Visibility="Collapsed">
                        <TextBlock Style="{StaticResource UmSectionLabelTextStyle}" Text="Immediate queue" />
                        <ListView
                            x:Name="ImmediateQueueList"
                            AutomationProperties.AutomationId="ImmediateQueueList"
                            AutomationProperties.Name="Immediate work queue"
                            IsItemClickEnabled="True"
                            ItemClick="ThreadCardList_ItemClick"
                            ItemTemplate="{StaticResource OperationsImmediateCardTemplate}"
                            SelectionMode="None" />
                    </StackPanel>

                    <controls:KanbanColumnBoard
                        x:Name="KanbanBoard"
                        ColumnOrderChanged="KanbanBoard_ColumnOrderChanged"
                        ColumnTransferRequested="KanbanBoard_ColumnTransferRequested"
                        CrossColumnDragAttempted="KanbanBoard_CrossColumnDragAttempted"
                        ItemClickRequested="KanbanBoard_ItemClickRequested"
                        Visibility="Collapsed" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <TeachingTip
            x:Name="QueueUxTeachingTip"
            Title="Unified work queue"
            Subtitle="One sortable queue replaces the old immediate lane. Use filter chips for Urgent, SLA, or Hanging. Board view is optional." />

        <Grid
            x:Name="WorkspaceLoadingOverlay"
            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
            Visibility="Collapsed">
            <ProgressRing
                Width="48"
                Height="48"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsActive="True" />
        </Grid>
    </Grid>
</UserControl>
