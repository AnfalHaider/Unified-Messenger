<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="UnifiedMessenger.Controls.OperationsCommandCenter"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:UnifiedMessenger.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shared="using:UnifiedMessenger.Controls.Shared"
    mc:Ignorable="d">

    <UserControl.Resources>
        <DataTemplate x:Key="OperationsImmediateCardTemplate" x:DataType="controls:OperationsThreadCardViewModel">
            <shared:OperationsThreadCardView
                Margin="{StaticResource UmMarginBottomSm}"
                DisplayStyle="Immediate"
                ViewModel="{Binding}" />
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <StackPanel
            x:Name="EmptyStatePanel"
            HorizontalAlignment="Center"
            Spacing="{StaticResource UmSpacingMd}"
            VerticalAlignment="Center"
            Visibility="Collapsed">
            <TextBlock
                HorizontalAlignment="Center"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="No professional accounts yet" />
            <TextBlock
                MaxWidth="420"
                HorizontalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Add a WhatsApp instance with Workspace set to Professional."
                TextAlignment="Center"
                TextWrapping="WrapWholeWords" />
            <Button
                HorizontalAlignment="Center"
                Click="AddProfessionalInstanceButton_Click"
                Content="Add instance" />
        </StackPanel>

        <ScrollViewer x:Name="MainContentScrollViewer" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="{StaticResource UmPaddingBottomXl}" Spacing="{StaticResource UmSpacingLg}">
                <Grid ColumnSpacing="{StaticResource UmSpacingMd}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="0" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel MinWidth="0" Spacing="{StaticResource UmSpacingXs}">
                        <TextBlock
                            x:Name="ScopeText"
                            MinWidth="0"
                            Style="{StaticResource UmScopeTextStyle}"
                            Text="Showing: All Branches" />
                        <TextBlock
                            x:Name="LastRefreshedText"
                            MinWidth="0"
                            Style="{StaticResource UmCaptionTextStyle}"
                            Text="Updated just now" />
                        <StackPanel
                            x:Name="BranchFilterChipPanel"
                            Orientation="Horizontal"
                            Spacing="{StaticResource UmSpacingSm}"
                            Visibility="Collapsed">
                            <TextBlock
                                x:Name="BranchFilterChipText"
                                MinWidth="0"
                                Style="{StaticResource UmBodyTextStyle}"
                                Text="Branch filter"
                                VerticalAlignment="Center" />
                            <Button
                                Click="ClearBranchFilterButton_Click"
                                Content="Clear"
                                Style="{StaticResource SubtleButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                    <Button
                        x:Name="RefreshCommandButton"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Click="RefreshCommandButton_Click"
                        Content="Refresh"
                        Style="{StaticResource SubtleButtonStyle}" />
                </Grid>

                <controls:BranchWorkspacePillBar x:Name="BranchWorkspacePillBar" />

                <shared:SurfaceCard>
                    <shared:SurfaceCard.CardBody>
                        <StackPanel Spacing="{StaticResource UmSpacingMd}">
                            <Grid ColumnSpacing="{StaticResource UmSpacingMd}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition MinWidth="0" Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Style="{StaticResource UmSectionLabelTextStyle}"
                                    Text="DATE RANGE" />
                                <Button
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Click="ClearDateRangeButton_Click"
                                    Content="Clear Filter"
                                    Style="{StaticResource SubtleButtonStyle}" />
                            </Grid>
                            <Grid ColumnSpacing="{StaticResource UmSpacingMd}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition MinWidth="140" Width="*" />
                                    <ColumnDefinition MinWidth="140" Width="*" />
                                </Grid.ColumnDefinitions>
                                <DatePicker
                                    x:Name="FromDatePicker"
                                    Grid.Column="0"
                                    AutomationProperties.Name="From date"
                                    DateChanged="DateRangePicker_DateChanged"
                                    Header="From" />
                                <DatePicker
                                    x:Name="ToDatePicker"
                                    Grid.Column="1"
                                    AutomationProperties.Name="To date"
                                    DateChanged="DateRangePicker_DateChanged"
                                    Header="To" />
                            </Grid>
                            <controls:MessageVolumeLineChart x:Name="MessageVolumeChart" />
                        </StackPanel>
                    </shared:SurfaceCard.CardBody>
                </shared:SurfaceCard>

                <Grid
                    x:Name="KpiMetricsGrid"
                    ColumnSpacing="{StaticResource UmSpacingMd}"
                    RowSpacing="{StaticResource UmSpacingMd}">
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup>
                            <VisualState x:Name="WideKpiLayout">
                                <VisualState.StateTriggers>
                                    <AdaptiveTrigger MinWindowWidth="900" />
                                </VisualState.StateTriggers>
                                <VisualState.Setters>
                                    <Setter Target="ImmediateActionCard.(Grid.Column)" Value="2" />
                                    <Setter Target="ImmediateActionCard.(Grid.Row)" Value="0" />
                                    <Setter Target="SlaBreachesCard.(Grid.Column)" Value="3" />
                                    <Setter Target="SlaBreachesCard.(Grid.Row)" Value="0" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition MinWidth="120" Width="*" />
                        <ColumnDefinition MinWidth="120" Width="*" />
                        <ColumnDefinition MinWidth="120" Width="*" />
                        <ColumnDefinition MinWidth="120" Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <shared:MetricCardView
                        x:Name="OpenThreadsCard"
                        Grid.Column="0"
                        Grid.Row="0"
                        IconGlyph="&#xE8BD;"
                        Label="Open threads"
                        Value="0" />
                    <shared:MetricCardView
                        x:Name="HangingLeadsCard"
                        Grid.Column="1"
                        Grid.Row="0"
                        IconGlyph="&#xE823;"
                        Label="Hanging leads"
                        Value="0" />
                    <shared:MetricCardView
                        x:Name="ImmediateActionCard"
                        Grid.Column="0"
                        Grid.Row="1"
                        IconGlyph="&#xE7BA;"
                        Label="Needs action"
                        Value="0" />
                    <shared:MetricCardView
                        x:Name="SlaBreachesCard"
                        Grid.Column="1"
                        Grid.Row="1"
                        IconGlyph="&#xE783;"
                        Label="SLA breaches"
                        Value="0" />
                </Grid>

                <StackPanel x:Name="ImmediateLaneSection" Spacing="{StaticResource UmSpacingSm}">
                    <TextBlock Style="{StaticResource UmSectionLabelTextStyle}" Text="Immediate queue" />
                    <TextBlock
                        x:Name="ImmediateQueueEmptyText"
                        Style="{StaticResource UmEmptyHintTextStyle}"
                        Text="No urgent threads in the current scope."
                        TextAlignment="Left"
                        Visibility="Collapsed" />
                    <ListView
                        x:Name="ImmediateQueueList"
                        IsItemClickEnabled="True"
                        ItemClick="ThreadCardList_ItemClick"
                        ItemTemplate="{StaticResource OperationsImmediateCardTemplate}"
                        SelectionMode="None"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled" />
                </StackPanel>

                <controls:KanbanColumnBoard
                    x:Name="KanbanBoard"
                    ColumnOrderChanged="KanbanBoard_ColumnOrderChanged"
                    ColumnTransferRequested="KanbanBoard_ColumnTransferRequested"
                    CrossColumnDragAttempted="KanbanBoard_CrossColumnDragAttempted"
                    ItemClickRequested="KanbanBoard_ItemClickRequested" />
            </StackPanel>
        </ScrollViewer>

        <Grid
            x:Name="WorkspaceLoadingOverlay"
            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
            Visibility="Collapsed">
            <ProgressRing
                Width="48"
                Height="48"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsActive="True" />
        </Grid>
    </Grid>
</UserControl>
