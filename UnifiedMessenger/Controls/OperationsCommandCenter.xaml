<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="UnifiedMessenger.Controls.OperationsCommandCenter"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:UnifiedMessenger.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <DataTemplate x:Key="OperationsImmediateCardTemplate">
            <Border
                Margin="0,0,0,8"
                Padding="12"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{Binding CardBorderBrush}"
                BorderThickness="{Binding CardBorderThickness}"
                CornerRadius="8">
                <StackPanel Spacing="6">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon FontSize="14" Glyph="{Binding PlatformGlyph}" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="{Binding CustomerName}" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="11" Opacity="0.65" Text="{Binding InboxLabel}" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="10" Opacity="0.5" Text="{Binding BranchName}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Border Grid.Column="2" Padding="6,2" Background="{Binding UrgencyBrush}" CornerRadius="4">
                            <TextBlock FontSize="11" Foreground="White" Text="{Binding UrgencyLabel}" />
                        </Border>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Border Padding="6,2" Background="{ThemeResource LayerFillColorAltBrush}" CornerRadius="4">
                            <TextBlock FontSize="10" Text="{Binding IntentLabel}" />
                        </Border>
                        <Border Padding="6,2" Background="{Binding SentimentBrush}" CornerRadius="4">
                            <TextBlock FontSize="10" Foreground="White" Text="{Binding SentimentLabel}" />
                        </Border>
                    </StackPanel>
                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding NextActionSummary}" TextWrapping="WrapWholeWords" />
                    <TextBlock FontSize="10" Opacity="0.45" Text="Click to open thread" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="OperationsKanbanCardTemplate">
            <Border
                Margin="0,0,0,6"
                Padding="8"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{Binding CardBorderBrush}"
                BorderThickness="{Binding CardBorderThickness}"
                CornerRadius="6">
                <StackPanel Spacing="4">
                    <Grid ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon FontSize="12" Glyph="{Binding PlatformGlyph}" Opacity="0.75" />
                        <TextBlock Grid.Column="1" FontSize="12" FontWeight="SemiBold" Text="{Binding CustomerName}" TextTrimming="CharacterEllipsis" />
                    </Grid>
                    <TextBlock FontSize="10" Opacity="0.55" Text="{Binding InboxLabel}" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="11" Opacity="0.85" Text="{Binding NextActionSummary}" TextWrapping="WrapWholeWords" MaxLines="3" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="OperationsBranchMetricCardTemplate">
            <Border
                Width="168"
                MinHeight="108"
                Padding="12"
                Background="{Binding CardBackgroundBrush}"
                BorderBrush="{Binding LatencyBorderBrush}"
                BorderThickness="2"
                CornerRadius="8">
                <StackPanel Spacing="4">
                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding BranchName}" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="{Binding LatencyBrush}" Text="{Binding LatencyDisplay}" />
                    <TextBlock FontSize="10" Opacity="0.75" Text="{Binding DetailDisplay}" TextWrapping="WrapWholeWords" />
                    <TextBlock FontSize="10" Opacity="0.55" Text="{Binding PlatformBreakdown}" Visibility="{Binding PlatformBreakdownVisibility}" TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="OperationsInsightFeedTemplate">
            <Border
                Margin="0,0,0,8"
                Padding="10"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                CornerRadius="6">
                <StackPanel Spacing="4">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontWeight="SemiBold" Text="{Binding CustomerName}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1" FontSize="10" Opacity="0.55" Text="{Binding SourceLabel}" />
                    </Grid>
                    <TextBlock FontSize="11" Opacity="0.65" Text="{Binding BranchName}" />
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Border Padding="6,2" Background="{ThemeResource LayerFillColorAltBrush}" CornerRadius="4" Visibility="{Binding IntentLabelVisibility}">
                            <TextBlock FontSize="10" Text="{Binding IntentLabel}" />
                        </Border>
                        <Border Padding="6,2" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="4" Visibility="{Binding UrgencyLabelVisibility}">
                            <TextBlock FontSize="10" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Text="{Binding UrgencyLabel}" />
                        </Border>
                    </StackPanel>
                    <TextBlock FontSize="12" Text="{Binding Summary}" TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer x:Name="MainContentScrollViewer" VerticalScrollBarVisibility="Auto">
            <Grid MinHeight="360" RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" MinHeight="360" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock FontSize="20" FontWeight="SemiBold" AutomationProperties.Name="Operations Command Center" Text="Operations Command Center" />
                    <TextBlock x:Name="ScopeText" FontSize="12" Opacity="0.65" Text="Showing: All Branches" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border MinWidth="100" Padding="12,8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="10" Opacity="0.65" Text="Open conversations" />
                                <TextBlock x:Name="OpenThreadCountText" FontSize="18" FontWeight="SemiBold" Text="0" />
                            </StackPanel>
                        </Border>
                        <Border MinWidth="100" Padding="12,8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="10" Opacity="0.65" Text="Hanging leads" />
                                <TextBlock x:Name="HangingLeadCountText" FontSize="18" FontWeight="SemiBold" Text="0" />
                            </StackPanel>
                        </Border>
                        <Border MinWidth="120" Padding="12,8" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="8">
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="10" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Opacity="0.85" Text="Revenue at risk" />
                                <TextBlock x:Name="RevenueAtRiskText" FontSize="22" FontWeight="Bold" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Text="PKR 0" />
                            </StackPanel>
                        </Border>
                        <Border MinWidth="110" Padding="12,8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="10" Opacity="0.65" Text="Avg reply" />
                                <TextBlock x:Name="AvgReplyTimeValue" FontSize="16" FontWeight="SemiBold" Text="—" />
                                <TextBlock x:Name="AvgReplyTimeSubtext" FontSize="10" Opacity="0.55" TextWrapping="WrapWholeWords" Visibility="Collapsed" />
                            </StackPanel>
                        </Border>
                        <Border MinWidth="90" Padding="12,8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="10" Opacity="0.65" Text="SLA breaches" />
                                <TextBlock x:Name="SlaBreachesValue" FontSize="18" FontWeight="SemiBold" Text="—" />
                                <TextBlock x:Name="SlaThresholdSubtext" FontSize="10" Opacity="0.55" TextWrapping="WrapWholeWords" Visibility="Collapsed" />
                            </StackPanel>
                        </Border>
                        <Border MinWidth="110" Padding="12,8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="10" Opacity="0.65" Text="Response rate (events)" />
                                <TextBlock x:Name="ResponseRateValue" FontSize="12" FontWeight="SemiBold" Text="—" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>
                        <Border MinWidth="90" Padding="12,8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="10" Opacity="0.65" Text="Immediate" />
                                <TextBlock x:Name="ImmediateActionCountText" FontSize="18" FontWeight="SemiBold" Text="0" />
                            </StackPanel>
                        </Border>
                        <Border MinWidth="90" Padding="12,8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="10" Opacity="0.65" Text="Peak hour" />
                                <TextBlock x:Name="PeakHourValue" FontSize="14" FontWeight="SemiBold" Text="—" />
                            </StackPanel>
                        </Border>
                        <Border MinWidth="110" Padding="12,8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="10" Opacity="0.65" Text="Daily trend" />
                                <TextBlock x:Name="DailyTrendValue" FontSize="12" FontWeight="SemiBold" Text="—" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Grid x:Name="MainSplitGrid" Grid.Row="2" ColumnSpacing="16" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.15*" MinWidth="320" />
                        <ColumnDefinition Width="*" MinWidth="300" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup>
                            <VisualState x:Name="WideLayout">
                                <VisualState.StateTriggers>
                                    <AdaptiveTrigger MinWindowWidth="960" />
                                </VisualState.StateTriggers>
                                <VisualState.Setters>
                                    <Setter Target="ActionPanel.(Grid.Column)" Value="0" />
                                    <Setter Target="ActionPanel.(Grid.Row)" Value="0" />
                                    <Setter Target="ContextPanel.(Grid.Column)" Value="1" />
                                    <Setter Target="ContextPanel.(Grid.Row)" Value="0" />
                                    <Setter Target="ContextPanel.(Grid.RowSpan)" Value="1" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="NarrowLayout">
                                <VisualState.StateTriggers>
                                    <AdaptiveTrigger MinWindowWidth="0" />
                                </VisualState.StateTriggers>
                                <VisualState.Setters>
                                    <Setter Target="ActionPanel.(Grid.Column)" Value="0" />
                                    <Setter Target="ActionPanel.(Grid.Row)" Value="0" />
                                    <Setter Target="ContextPanel.(Grid.Column)" Value="0" />
                                    <Setter Target="ContextPanel.(Grid.Row)" Value="1" />
                                    <Setter Target="ContextPanel.(Grid.RowSpan)" Value="1" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>

                    <StackPanel x:Name="ActionPanel" Spacing="12">
                        <Border Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                            <Grid RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" MaxHeight="280" />
                                </Grid.RowDefinitions>
                                <TextBlock FontWeight="SemiBold" Text="Immediate action lane" />
                                <ListView
                                    x:Name="ImmediateQueueList"
                                    Grid.Row="1"
                                    IsItemClickEnabled="True"
                                    ItemClick="ThreadCardList_ItemClick"
                                    ItemTemplate="{StaticResource OperationsImmediateCardTemplate}"
                                    SelectionMode="None" />
                                <TextBlock
                                    x:Name="ImmediateQueueEmptyText"
                                    Grid.Row="1"
                                    HorizontalAlignment="Center"
                                    Margin="0,16,0,0"
                                    Opacity="0.6"
                                    Text="No urgent threads right now."
                                    Visibility="Collapsed" />
                            </Grid>
                        </Border>

                        <Border Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                            <Grid RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" MinHeight="200" />
                                </Grid.RowDefinitions>
                                <TextBlock FontWeight="SemiBold" Text="Branch workspace kanban" />
                                <TabView
                                    x:Name="BranchWorkspaceTabs"
                                    Grid.Row="1"
                                    TabWidthMode="SizeToContent"
                                    CanDragTabs="False"
                                    CanReorderTabs="False"
                                    IsAddTabButtonVisible="False" />
                                <Grid Grid.Row="2" ColumnSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock FontSize="11" FontWeight="SemiBold" Text="New" />
                                        <ListView x:Name="NewInquiriesList" IsItemClickEnabled="True" ItemClick="ThreadCardList_ItemClick" ItemTemplate="{StaticResource OperationsKanbanCardTemplate}" MaxHeight="320" SelectionMode="None" />
                                        <TextBlock x:Name="NewInquiriesEmptyText" FontSize="10" Opacity="0.55" Text="No new inquiries." Visibility="Collapsed" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock FontSize="11" FontWeight="SemiBold" Text="Hanging" />
                                        <ListView x:Name="HangingLeadsList" IsItemClickEnabled="True" ItemClick="ThreadCardList_ItemClick" ItemTemplate="{StaticResource OperationsKanbanCardTemplate}" MaxHeight="320" SelectionMode="None" />
                                        <TextBlock x:Name="HangingLeadsEmptyText" FontSize="10" Opacity="0.55" Text="No hanging leads." Visibility="Collapsed" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="4">
                                        <TextBlock FontSize="11" FontWeight="SemiBold" Text="Resolved" />
                                        <ListView x:Name="ResolvedList" IsItemClickEnabled="True" ItemClick="ThreadCardList_ItemClick" ItemTemplate="{StaticResource OperationsKanbanCardTemplate}" MaxHeight="320" SelectionMode="None" />
                                        <TextBlock x:Name="ResolvedEmptyText" FontSize="10" Opacity="0.55" Text="Nothing resolved yet." Visibility="Collapsed" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="ContextPanel" Grid.Column="1" Spacing="12">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <ListView
                                x:Name="BranchMetricsList"
                                IsItemClickEnabled="True"
                                ItemClick="BranchMetricsList_ItemClick"
                                ItemTemplate="{StaticResource OperationsBranchMetricCardTemplate}"
                                SelectionMode="None">
                                <ListView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8" />
                                    </ItemsPanelTemplate>
                                </ListView.ItemsPanel>
                            </ListView>
                        </ScrollViewer>
                        <TextBlock x:Name="BranchMetricsEmptyText" FontSize="11" Opacity="0.55" Text="Branch metrics appear when threads are tracked." Visibility="Collapsed" />

                        <ItemsControl x:Name="PlatformHealthItems">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Ellipse Width="8" Height="8" Fill="{Binding StatusBrush}" />
                                            <TextBlock FontSize="11" Text="{Binding Label}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Expander x:Name="PlatformIntelligenceExpander" Header="Platform intelligence" IsExpanded="False">
                            <StackPanel Spacing="12">
                                <StackPanel x:Name="GoogleIntelligenceSection" Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Text="Google Business · Customer trust" />
                                    <TextBlock x:Name="AggregateRatingValue" FontSize="18" FontWeight="SemiBold" Text="—" />
                                    <TextBlock x:Name="UnrepliedReviewsValue" FontSize="11" Opacity="0.65" Text="—" />
                                    <ListView x:Name="GoogleReviewAlertsList" MaxHeight="140" SelectionChanged="GoogleReviewAlertsList_SelectionChanged" SelectionMode="Single">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Spacing="2">
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding ReviewerName}" />
                                                    <TextBlock FontSize="11" Opacity="0.75" Text="{Binding Snippet}" TextTrimming="CharacterEllipsis" MaxLines="2" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                    <TextBlock x:Name="GoogleReviewAlertsEmptyText" Opacity="0.6" TextWrapping="WrapWholeWords" Visibility="Collapsed" />
                                    <TextBox x:Name="ReviewReplyBox" AcceptsReturn="True" PlaceholderText="Draft a review reply..." MaxHeight="72" TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="SubmitReviewReplyButton" Click="SubmitReviewReplyButton_Click" Content="Insert draft" />
                                        <Button Click="OpenSelectedReviewInstanceButton_Click" Content="Open Google" />
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel x:Name="MetaIntelligenceSection" Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Text="Meta Business · Response analytics" />
                                    <TextBlock x:Name="MetaAverageResponseValue" FontSize="20" FontWeight="SemiBold" Text="—" />
                                    <TextBlock x:Name="MetaEfficiencyRatingValue" FontSize="12" Opacity="0.75" Text="—" />
                                    <TextBlock x:Name="MetaSampleCountValue" FontSize="11" Opacity="0.65" Text="Samples: —" />
                                    <TextBlock x:Name="MetaLastInboundValue" FontSize="11" Opacity="0.65" Text="Last inbound: —" />
                                    <TextBlock x:Name="MetaLastReplyValue" FontSize="11" Opacity="0.65" Text="Last reply: —" />
                                    <TextBlock x:Name="MetaPendingResponseText" FontSize="11" Opacity="0.75" TextWrapping="WrapWholeWords" Visibility="Collapsed" />
                                    <TextBlock x:Name="MetaResponseEmptyText" Opacity="0.6" TextWrapping="WrapWholeWords" Visibility="Collapsed" />
                                </StackPanel>
                                <Button x:Name="RefreshPlatformDataButton" Click="RefreshPlatformDataButton_Click" Content="Refresh platform data" />
                            </StackPanel>
                        </Expander>

                        <Border Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="Operational highlights" />
                                <ListView x:Name="OperationalHighlightsList" IsItemClickEnabled="True" ItemClick="OperationalHighlightsList_ItemClick" MaxHeight="160" SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Spacing="2" Padding="0,4">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock FontSize="11" Opacity="0.75" Text="{Binding Subtitle}" TextWrapping="WrapWholeWords" />
                                                <TextBlock FontSize="10" Opacity="0.45" Text="{Binding InstanceDisplayName}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <TextBlock x:Name="OperationalHighlightsEmptyText" Opacity="0.6" Text="Activity highlights appear after message traffic is recorded." Visibility="Collapsed" />
                            </StackPanel>
                        </Border>

                        <Expander x:Name="AnalyticsTrendsExpander" Header="Analytics &amp; trends" IsExpanded="False">
                            <StackPanel Spacing="12">
                                <Border Padding="12" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8">
                                    <StackPanel Spacing="8">
                                        <TextBlock FontWeight="SemiBold" Text="Message volume (7 days)" />
                                        <controls:WeeklyActivityChart x:Name="WeeklyChart" Height="120" />
                                        <TextBlock x:Name="AnalyticsVolumeEmptyText" Opacity="0.6" Text="No message volume recorded for this scope yet." Visibility="Collapsed" />
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Sent: " Opacity="0.65" />
                                            <TextBlock x:Name="SentCountValue" Grid.Column="0" Margin="36,0,0,0" Text="—" />
                                            <TextBlock Grid.Column="1" Opacity="0.65" Text="Received:" />
                                            <TextBlock x:Name="ReceivedCountValue" Grid.Column="1" Margin="72,0,0,0" Text="—" />
                                            <Button Grid.Column="2" Click="ExportAnalyticsButton_Click" Content="Export" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Padding="12" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8">
                                    <StackPanel Spacing="8">
                                        <TextBlock FontWeight="SemiBold" Text="Sentiment (7 days)" />
                                        <controls:SentimentActivityChart x:Name="SentimentChart" Height="100" />
                                        <TextBlock x:Name="SentimentEmptyText" Opacity="0.6" Text="Sentiment breakdown appears after triage classifies inbound messages." Visibility="Collapsed" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Expander>

                        <Border Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="AI insight feed" />
                                <ListView x:Name="AiInsightFeedList" IsItemClickEnabled="True" ItemClick="InsightFeedList_ItemClick" ItemTemplate="{StaticResource OperationsInsightFeedTemplate}" MaxHeight="280" SelectionMode="None" />
                                <TextBlock x:Name="AiInsightFeedEmptyText" Opacity="0.6" Text="Insights appear as messages are classified." Visibility="Collapsed" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="HealthChipsSection" Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Visibility="Collapsed">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="Data health" />
                                <ItemsControl x:Name="HealthChipsItems">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="6" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8,4" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="4">
                                                <TextBlock FontSize="10" Text="{Binding Summary}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </ScrollViewer>

        <Border
            x:Name="EmptyStatePanel"
            Padding="32"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            CornerRadius="8"
            Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" MaxWidth="420" Spacing="12">
                <FontIcon HorizontalAlignment="Center" FontSize="40" Glyph="&#xE731;" Opacity="0.45" />
                <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Text="No professional accounts yet" TextAlignment="Center" />
                <TextBlock HorizontalAlignment="Center" Opacity="0.7" Text="Add a Professional workspace instance to use the Operations Command Center." TextAlignment="Center" TextWrapping="WrapWholeWords" />
                <Button HorizontalAlignment="Center" Click="AddProfessionalInstanceButton_Click" Content="Add professional instance" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
