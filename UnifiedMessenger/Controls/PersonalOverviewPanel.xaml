<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="UnifiedMessenger.Controls.PersonalOverviewPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <AutoSuggestBox
                x:Name="GlobalSearchBox"
                AutomationProperties.Name="Search personal accounts"
                PlaceholderText="Search personal accounts, senders, or messages..."
                QueryIcon="Find"
                QuerySubmitted="GlobalSearchBox_QuerySubmitted"
                SuggestionChosen="GlobalSearchBox_SuggestionChosen"
                TextChanged="GlobalSearchBox_TextChanged" />

            <Grid
                x:Name="SummaryCardsGrid"
                Grid.Row="1"
                ColumnSpacing="12"
                RowSpacing="12">
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup>
                        <VisualState x:Name="WideSummaryLayout">
                            <VisualState.StateTriggers>
                                <AdaptiveTrigger MinWindowWidth="760" />
                            </VisualState.StateTriggers>
                        </VisualState>
                        <VisualState x:Name="NarrowSummaryLayout">
                            <VisualState.Setters>
                                <Setter Target="SummaryCardUnread.(Grid.Column)" Value="0" />
                                <Setter Target="SummaryCardUnread.(Grid.Row)" Value="1" />
                                <Setter Target="SummaryCardMemory.(Grid.Column)" Value="1" />
                                <Setter Target="SummaryCardMemory.(Grid.Row)" Value="1" />
                                <Setter Target="SummaryCardActive.(Grid.Column)" Value="0" />
                                <Setter Target="SummaryCardActive.(Grid.ColumnSpan)" Value="2" />
                                <Setter Target="SummaryCardActive.(Grid.Row)" Value="2" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    x:Name="SummaryCardAccounts"
                    Padding="14"
                    Style="{StaticResource DashboardCardStyle}">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE77B;" Opacity="0.7" />
                            <TextBlock FontSize="11" Opacity="0.65" Text="Accounts" />
                        </StackPanel>
                        <TextBlock
                            x:Name="ActiveAccountsValue"
                            FontSize="24"
                            FontWeight="SemiBold"
                            Text="0" />
                    </StackPanel>
                </Border>

                <Border
                    x:Name="SummaryCardUnread"
                    Grid.Column="1"
                    Padding="14"
                    Style="{StaticResource DashboardCardStyle}">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE715;" Opacity="0.7" />
                            <TextBlock FontSize="11" Opacity="0.65" Text="Unread" />
                        </StackPanel>
                        <TextBlock
                            x:Name="UnreadValue"
                            FontSize="24"
                            FontWeight="SemiBold"
                            Text="0" />
                    </StackPanel>
                </Border>

                <Border
                    x:Name="SummaryCardMemory"
                    Grid.Row="1"
                    Padding="14"
                    Style="{StaticResource DashboardCardStyle}">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE9F5;" Opacity="0.7" />
                            <TextBlock FontSize="11" Opacity="0.65" Text="App memory" />
                        </StackPanel>
                        <TextBlock
                            x:Name="MemoryValue"
                            FontSize="24"
                            FontWeight="SemiBold"
                            Text="0 MB" />
                    </StackPanel>
                </Border>

                <Border
                    x:Name="SummaryCardActive"
                    Grid.Row="1"
                    Grid.Column="1"
                    Padding="14"
                    Style="{StaticResource DashboardCardStyle}">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE7B3;" Opacity="0.7" />
                            <TextBlock FontSize="11" Opacity="0.65" Text="Active view" />
                        </StackPanel>
                        <TextBlock
                            x:Name="VisibleAccountValue"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="None"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="2" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button
                    x:Name="OpenBusiestInboxButton"
                    Click="OpenBusiestInboxButton_Click"
                    Content="Open busiest inbox"
                    Visibility="Collapsed" />
                <TextBlock
                    x:Name="PersonalLastUpdatedText"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    Opacity="0.55"
                    Text="Updated just now"
                    VerticalAlignment="Center" />
            </Grid>

            <Grid
                x:Name="ContentGrid"
                Grid.Row="3"
                ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="LeftColumn" Width="*" MinWidth="280" />
                    <ColumnDefinition x:Name="RightColumn" Width="*" MinWidth="260" />
                </Grid.ColumnDefinitions>

                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup>
                        <VisualState x:Name="WideLayout">
                            <VisualState.StateTriggers>
                                <AdaptiveTrigger MinWindowWidth="860" />
                            </VisualState.StateTriggers>
                            <VisualState.Setters>
                                <Setter Target="LeftColumn.(Grid.Column)" Value="0" />
                                <Setter Target="LeftColumn.(Grid.Row)" Value="0" />
                                <Setter Target="RightColumn.(Grid.Column)" Value="1" />
                                <Setter Target="RightColumn.(Grid.Row)" Value="0" />
                                <Setter Target="LeftColumn.(Grid.ColumnSpan)" Value="1" />
                                <Setter Target="RightColumn.(Grid.ColumnSpan)" Value="1" />
                                <Setter Target="ContentGrid.RowDefinitions[0].Height" Value="Auto" />
                                <Setter Target="ContentGrid.RowDefinitions[1].Height" Value="0" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="NarrowLayout">
                            <VisualState.Setters>
                                <Setter Target="LeftColumn.(Grid.Column)" Value="0" />
                                <Setter Target="LeftColumn.(Grid.Row)" Value="0" />
                                <Setter Target="RightColumn.(Grid.Column)" Value="0" />
                                <Setter Target="RightColumn.(Grid.Row)" Value="1" />
                                <Setter Target="LeftColumn.(Grid.ColumnSpan)" Value="2" />
                                <Setter Target="RightColumn.(Grid.ColumnSpan)" Value="2" />
                                <Setter Target="ContentGrid.RowDefinitions[0].Height" Value="Auto" />
                                <Setter Target="ContentGrid.RowSpacing" Value="16" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    MinHeight="200"
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" MinHeight="120" />
                        </Grid.RowDefinitions>
                        <TextBlock FontWeight="SemiBold" Text="Recent Activity" />
                        <ListView
                            x:Name="RecentActivityList"
                            Grid.Row="1"
                            IsItemClickEnabled="True"
                            ItemClick="RecentActivityList_ItemClick"
                            MaxHeight="420"
                            SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="8,10" ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse
                                            Width="8"
                                            Height="8"
                                            Margin="0,6,0,0"
                                            VerticalAlignment="Top"
                                            Fill="{Binding AccentBrush}"
                                            Visibility="{Binding UnreadIndicatorVisibility}" />
                                        <FontIcon
                                            Grid.Column="1"
                                            VerticalAlignment="Top"
                                            FontSize="14"
                                            Foreground="{Binding AccentBrush}"
                                            Glyph="{Binding IconGlyph}" />
                                        <StackPanel Grid.Column="2" Spacing="2">
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    FontWeight="SemiBold"
                                                    Text="{Binding Title}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    FontSize="11"
                                                    Opacity="0.55"
                                                    Text="{Binding RelativeTimeText}" />
                                            </Grid>
                                            <TextBlock
                                                FontSize="12"
                                                Opacity="0.75"
                                                Text="{Binding Body}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                FontSize="11"
                                                Opacity="0.55"
                                                Text="{Binding InstanceDisplayName}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <StackPanel
                            x:Name="RecentActivityEmptyPanel"
                            Grid.Row="1"
                            HorizontalAlignment="Center"
                            Spacing="8"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                            <FontIcon
                                x:Name="RecentActivityEmptyIcon"
                                HorizontalAlignment="Center"
                                FontSize="28"
                                Glyph="&#xE7F3;"
                                Opacity="0.45" />
                            <TextBlock
                                x:Name="RecentActivityEmptyTitle"
                                HorizontalAlignment="Center"
                                FontWeight="SemiBold"
                                Text="No recent activity"
                                TextAlignment="Center" />
                            <TextBlock
                                x:Name="RecentActivityEmptyText"
                                MaxWidth="360"
                                HorizontalAlignment="Center"
                                Opacity="0.65"
                                Text="No recent notifications from personal accounts."
                                TextAlignment="Center"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock FontWeight="SemiBold" Text="Account Status" />
                        <TextBlock
                            FontSize="12"
                            Opacity="0.65"
                            Text="Connection health and unread counts for personal accounts."
                            TextWrapping="WrapWholeWords" />

                        <ListView
                            x:Name="InstanceTilesList"
                            IsItemClickEnabled="True"
                            ItemClick="InstanceTilesList_ItemClick"
                            SelectionMode="None"
                            Visibility="Visible">
                            <ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid MaximumRowsOrColumns="2" Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ListView.ItemsPanel>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Width="168"
                                        Margin="0,0,8,8"
                                        Padding="10"
                                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                                        BorderBrush="{Binding AccentBrush}"
                                        BorderThickness="2,0,0,0"
                                        CornerRadius="6">
                                        <StackPanel Spacing="6">
                                            <Grid ColumnSpacing="6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon
                                                        FontSize="12"
                                                        Foreground="{Binding AccentBrush}"
                                                        Glyph="{Binding IconGlyph}" />
                                                    <TextBlock
                                                        FontWeight="SemiBold"
                                                        Text="{Binding DisplayName}"
                                                        TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <FontIcon
                                                    x:Name="MutedIndicatorIcon"
                                                    Grid.Column="1"
                                                    AutomationProperties.Name="Notifications muted"
                                                    FontSize="11"
                                                    Glyph="&#xE74F;"
                                                    Opacity="0.55"
                                                    ToolTipService.ToolTip="Notifications muted"
                                                    Visibility="{Binding MutedIndicatorVisibility}" />
                                            </Grid>
                                            <TextBlock
                                                FontSize="11"
                                                Opacity="0.6"
                                                Text="{Binding PlatformLabel}" />
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Border
                                                    Padding="6,2"
                                                    Background="{Binding ConnectionBrush}"
                                                    CornerRadius="4">
                                                    <TextBlock
                                                        FontSize="10"
                                                        Foreground="White"
                                                        Text="{Binding ConnectionStatusLabel}" />
                                                </Border>
                                                <Border
                                                    Padding="6,2"
                                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                    CornerRadius="4"
                                                    Visibility="{Binding UnreadBadgeVisibility}">
                                                    <TextBlock
                                                        FontSize="10"
                                                        Text="{Binding UnreadBadgeText}" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock
                                                FontSize="11"
                                                Opacity="0.75"
                                                Text="{Binding DetailLine}"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="NoWrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <StackPanel
                            x:Name="InstanceTilesEmptyPanel"
                            HorizontalAlignment="Center"
                            Spacing="8"
                            Visibility="Collapsed">
                            <FontIcon
                                HorizontalAlignment="Center"
                                FontSize="24"
                                Glyph="&#xE8FA;"
                                Opacity="0.45" />
                            <TextBlock
                                x:Name="InstanceTilesEmptyText"
                                MaxWidth="320"
                                HorizontalAlignment="Center"
                                Opacity="0.65"
                                Text="Personal account status will appear here after you add an account."
                                TextAlignment="Center"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
