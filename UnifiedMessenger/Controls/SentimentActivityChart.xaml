<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="UnifiedMessenger.Controls.SentimentActivityChart"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shared="using:UnifiedMessenger.Controls.Shared"
    mc:Ignorable="d">

    <StackPanel Spacing="8">
        <TextBlock
            x:Name="SummaryText"
            FontSize="12"
            Opacity="0.7"
            Text="Awaiting classified messages" />
        <shared:AccessibleChartHost
            x:Name="ChartAccessibilityHost"
            AutomationProperties.Name="Sentiment activity chart">
            <shared:AccessibleChartHost.ChartContent>
                <Grid x:Name="ChartHost" MinHeight="110" ColumnSpacing="6" />
            </shared:AccessibleChartHost.ChartContent>
        </shared:AccessibleChartHost>
        <TextBlock
            x:Name="EmptyHint"
            FontSize="12"
            Opacity="0.55"
            Text="Sentiment appears after inbound professional messages are triaged."
            Visibility="Collapsed" />
    </StackPanel>
</UserControl>
