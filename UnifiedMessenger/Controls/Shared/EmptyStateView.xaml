<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="UnifiedMessenger.Controls.Shared.EmptyStateView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel
        HorizontalAlignment="Center"
        MaxWidth="420"
        Spacing="12">
        <FontIcon
            HorizontalAlignment="Center"
            FontSize="40"
            Foreground="{StaticResource UmBrandTealBrush}"
            Glyph="{x:Bind IconGlyph, Mode=OneWay}"
            Opacity="0.85" />
        <TextBlock
            HorizontalAlignment="Center"
            FontWeight="SemiBold"
            Text="{x:Bind Title, Mode=OneWay}"
            TextAlignment="Center" />
        <TextBlock
            HorizontalAlignment="Center"
            Opacity="0.7"
            Text="{x:Bind Hint, Mode=OneWay}"
            TextAlignment="Center"
            TextWrapping="WrapWholeWords" />
        <ContentPresenter
            x:Name="ActionPresenter"
            HorizontalAlignment="Center"
            Content="{x:Bind ActionContent, Mode=OneWay}" />
    </StackPanel>
</UserControl>
