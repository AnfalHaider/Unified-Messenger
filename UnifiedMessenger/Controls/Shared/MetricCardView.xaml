<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="UnifiedMessenger.Controls.Shared.MetricCardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="MetricSubtextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Opacity" Value="0.55" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>
    </UserControl.Resources>

    <Border x:Name="CardBorder" MinWidth="90" Padding="12,8" Style="{StaticResource DashboardMetricCardStyle}">
        <StackPanel Spacing="4">
            <TextBlock
                x:Name="LabelText"
                FontSize="11"
                Opacity="0.65"
                Text="{x:Bind Label, Mode=OneWay}" />
            <TextBlock
                x:Name="ValueText"
                FontSize="20"
                FontWeight="SemiBold"
                Foreground="{StaticResource UmBrandBlueBrush}"
                Text="{x:Bind Value, Mode=OneWay}" />
            <TextBlock
                Style="{StaticResource MetricSubtextStyle}"
                Text="{x:Bind Subtext, Mode=OneWay}"
                Visibility="{x:Bind SubtextVisibility, Mode=OneWay}" />
        </StackPanel>
    </Border>

    <VisualStateManager.VisualStateGroups>
        <VisualStateGroup x:Name="AccentStates">
            <VisualState x:Name="Normal" />
            <VisualState x:Name="Accent">
                <VisualState.Setters>
                    <Setter Target="CardBorder.Background" Value="{ThemeResource AccentFillColorDefaultBrush}" />
                    <Setter Target="CardBorder.BorderThickness" Value="0" />
                    <Setter Target="LabelText.Foreground" Value="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                    <Setter Target="LabelText.Opacity" Value="0.85" />
                    <Setter Target="ValueText.Foreground" Value="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                    <Setter Target="ValueText.FontSize" Value="22" />
                    <Setter Target="ValueText.FontWeight" Value="Bold" />
                </VisualState.Setters>
            </VisualState>
        </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>
</UserControl>
