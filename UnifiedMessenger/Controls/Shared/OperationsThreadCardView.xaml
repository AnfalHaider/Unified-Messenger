<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="UnifiedMessenger.Controls.Shared.OperationsThreadCardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        Padding="{x:Bind CardPadding, Mode=OneTime}"
        Background="{ThemeResource LayerFillColorDefaultBrush}"
        BorderBrush="{x:Bind ViewModel.CardBorderBrush, Mode=OneTime}"
        BorderThickness="{x:Bind ViewModel.CardBorderThickness, Mode=OneTime}"
        CornerRadius="8"
        ToolTipService.ToolTip="{x:Bind ViewModel.NextActionSummary, Mode=OneTime}">
        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border
                Background="{x:Bind ViewModel.CardBorderBrush, Mode=OneTime}"
                CornerRadius="2"
                Visibility="{x:Bind SlaStripeVisibility, Mode=OneTime}" />
            <StackPanel Grid.Column="1" Spacing="{x:Bind ContentSpacing, Mode=OneTime}">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon
                        FontSize="{x:Bind PlatformIconSize, Mode=OneTime}"
                        Glyph="{x:Bind ViewModel.PlatformGlyph, Mode=OneTime}"
                        Opacity="0.75" />
                    <TextBlock
                        Grid.Column="1"
                        FontSize="{x:Bind CustomerNameFontSize, Mode=OneTime}"
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.CustomerName, Mode=OneTime}"
                        TextTrimming="CharacterEllipsis" />
                    <Border
                        Grid.Column="2"
                        Padding="{x:Bind UrgencyBadgePadding, Mode=OneTime}"
                        Background="{x:Bind ViewModel.UrgencyBrush, Mode=OneTime}"
                        CornerRadius="4">
                        <TextBlock
                            FontSize="{x:Bind UrgencyBadgeFontSize, Mode=OneTime}"
                            Foreground="White"
                            Text="{x:Bind ViewModel.UrgencyLabel, Mode=OneTime}" />
                    </Border>
                </Grid>
                <TextBlock
                    FontSize="10"
                    Opacity="0.55"
                    Text="{x:Bind ViewModel.InboxLabel, Mode=OneTime}"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    FontSize="10"
                    Opacity="0.45"
                    Text="{x:Bind ViewModel.BranchName, Mode=OneTime}"
                    TextTrimming="CharacterEllipsis"
                    Visibility="{x:Bind ViewModel.BranchNameVisibility, Mode=OneTime}" />
                <StackPanel Orientation="Horizontal" Spacing="6" Visibility="{x:Bind TagRowVisibility, Mode=OneTime}">
                    <Border Padding="6,2" Background="{ThemeResource LayerFillColorAltBrush}" CornerRadius="4">
                        <TextBlock FontSize="10" Text="{x:Bind ViewModel.IntentLabel, Mode=OneTime}" />
                    </Border>
                    <Border Padding="6,2" Background="{x:Bind ViewModel.SentimentBrush, Mode=OneTime}" CornerRadius="4">
                        <TextBlock FontSize="10" Foreground="White" Text="{x:Bind ViewModel.SentimentLabel, Mode=OneTime}" />
                    </Border>
                </StackPanel>
                <TextBlock
                    FontSize="{x:Bind SummaryFontSize, Mode=OneTime}"
                    FontWeight="{x:Bind SummaryFontWeight, Mode=OneTime}"
                    MaxLines="{x:Bind SummaryMaxLines, Mode=OneTime}"
                    Opacity="0.85"
                    Text="{x:Bind ViewModel.NextActionSummary, Mode=OneTime}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="WrapWholeWords" />
                <TextBlock
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="{x:Bind ViewModel.SlaBrush, Mode=OneTime}"
                    Text="{x:Bind ViewModel.SlaText, Mode=OneTime}"
                    Visibility="{x:Bind ViewModel.SlaVisibility, Mode=OneTime}" />
                <TextBlock
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="{x:Bind ViewModel.DeliveryStatusBrush, Mode=OneTime}"
                    Text="{x:Bind ViewModel.DeliveryStatusLabel, Mode=OneTime}"
                    Visibility="{x:Bind ViewModel.DeliveryStatusVisibility, Mode=OneTime}" />
                <TextBlock
                    FontSize="10"
                    Opacity="0.65"
                    Text="{x:Bind ViewModel.RevenueDisplay, Mode=OneTime}"
                    Visibility="{x:Bind ViewModel.RevenueVisibility, Mode=OneTime}" />
                <TextBlock
                    FontSize="10"
                    Opacity="0.45"
                    Text="Click to open thread"
                    Visibility="{x:Bind ClickHintVisibility, Mode=OneTime}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
