<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="UnifiedMessenger.Controls.UnifiedMessengerControlCenter"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <DataTemplate x:Key="UnifiedMessengerBranchMetricCardTemplate">
            <Border
                Width="168"
                MinHeight="108"
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{Binding LatencyBorderBrush}"
                BorderThickness="2"
                CornerRadius="8">
                <StackPanel Spacing="6">
                    <TextBlock
                        FontSize="13"
                        FontWeight="SemiBold"
                        Text="{Binding BranchName}"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="{Binding LatencyBrush}"
                        Text="{Binding LatencyDisplay}" />
                    <TextBlock
                        FontSize="11"
                        Opacity="0.75"
                        Text="{Binding UnresolvedDisplay}" />
                    <TextBlock
                        FontSize="11"
                        Opacity="0.75"
                        Text="{Binding RevenueDisplay}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="UnifiedMessengerImmediateCardTemplate">
            <Border
                Margin="0,0,0,8"
                Padding="12"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{Binding CardBorderBrush}"
                BorderThickness="{Binding CardBorderThickness}"
                CornerRadius="8">
                <StackPanel Spacing="6">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon FontSize="14" Glyph="{Binding PlatformGlyph}" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{Binding CustomerName}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                FontSize="11"
                                Opacity="0.65"
                                Text="{Binding BranchName}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Border
                            Grid.Column="2"
                            Padding="6,2"
                            Background="{Binding UrgencyBrush}"
                            CornerRadius="4">
                            <TextBlock
                                FontSize="11"
                                Foreground="White"
                                Text="{Binding UrgencyLabel}" />
                        </Border>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Border
                            Padding="6,2"
                            Background="{ThemeResource LayerFillColorAltBrush}"
                            CornerRadius="4">
                            <TextBlock FontSize="10" Text="{Binding IntentLabel}" />
                        </Border>
                        <Border
                            Padding="6,2"
                            Background="{Binding SentimentBrush}"
                            CornerRadius="4">
                            <TextBlock
                                FontSize="10"
                                Foreground="White"
                                Text="{Binding SentimentLabel}" />
                        </Border>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="10"
                            Opacity="0.65"
                            Text="{Binding RevenueDisplay}"
                            Visibility="{Binding RevenueVisibility}" />
                    </StackPanel>
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Text="{Binding NextActionSummary}"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        FontSize="11"
                        Foreground="{Binding SlaBrush}"
                        Text="{Binding SlaText}"
                        Visibility="{Binding SlaVisibility}" />
                    <TextBlock
                        FontSize="10"
                        Opacity="0.45"
                        Text="Ctrl + Space to draft" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="UnifiedMessengerKanbanCardTemplate">
            <Border
                Margin="0,0,0,6"
                Padding="8"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{Binding CardBorderBrush}"
                BorderThickness="{Binding CardBorderThickness}"
                CornerRadius="6">
                <StackPanel Spacing="4">
                    <Grid ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon FontSize="12" Glyph="{Binding PlatformGlyph}" />
                        <TextBlock
                            Grid.Column="1"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Text="{Binding CustomerName}"
                            TextTrimming="CharacterEllipsis" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock
                            FontSize="10"
                            Opacity="0.7"
                            Text="{Binding IntentLabel}" />
                        <TextBlock FontSize="10" Opacity="0.45" Text="·" />
                        <TextBlock
                            FontSize="10"
                            Opacity="0.7"
                            Text="{Binding SentimentLabel}" />
                    </StackPanel>
                    <TextBlock
                        FontSize="11"
                        Opacity="0.85"
                        Text="{Binding NextActionSummary}"
                        TextWrapping="WrapWholeWords"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        FontSize="10"
                        Foreground="{Binding SlaBrush}"
                        Text="{Binding SlaText}"
                        Visibility="{Binding SlaVisibility}" />
                    <TextBlock
                        FontSize="10"
                        Opacity="0.45"
                        Text="{Binding RevenueDisplay}"
                        Visibility="{Binding RevenueVisibility}" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="320" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
                <TextBlock
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="Unified Messenger Control Center" />
                <TextBlock
                    x:Name="ScopeText"
                    FontSize="12"
                    Opacity="0.65"
                    Text="Multi-branch triage and revenue intelligence" />
            </StackPanel>

            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="8">
                <Border
                    MinWidth="120"
                    Padding="12,8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="2">
                        <TextBlock FontSize="10" Opacity="0.65" Text="Open threads" />
                        <TextBlock
                            x:Name="OpenThreadCountText"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="0" />
                    </StackPanel>
                </Border>
                <Border
                    MinWidth="120"
                    Padding="12,8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="2">
                        <TextBlock FontSize="10" Opacity="0.65" Text="Hanging leads" />
                        <TextBlock
                            x:Name="HangingLeadCountText"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="0" />
                    </StackPanel>
                </Border>
                <Border
                    MinWidth="180"
                    Padding="16,12"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    CornerRadius="8">
                    <StackPanel Spacing="2">
                        <TextBlock
                            FontSize="11"
                            Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                            Opacity="0.85"
                            Text="Revenue at risk" />
                        <TextBlock
                            x:Name="RevenueAtRiskText"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                            Text="PKR 0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Spacing="10">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl
                    x:Name="BranchMetricsItems"
                    ItemTemplate="{StaticResource UnifiedMessengerBranchMetricCardTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <ItemsControl x:Name="PlatformHealthItems">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Padding="10,6"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse
                                    Width="8"
                                    Height="8"
                                    Fill="{Binding StatusBrush}" />
                                <TextBlock FontSize="12" Text="{Binding Label}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <Grid Grid.Row="2" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300" />
                <ColumnDefinition Width="1.15*" MinWidth="360" />
            </Grid.ColumnDefinitions>

            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontWeight="SemiBold" Text="Immediate action lane" />
                    <TextBlock
                        Grid.Row="1"
                        FontSize="12"
                        Opacity="0.65"
                        Text="AI next-action summaries · urgency ≥ 4 or critical sentiment" />
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <ItemsControl
                                x:Name="ImmediateQueueItems"
                                ItemTemplate="{StaticResource UnifiedMessengerImmediateCardTemplate}" />
                            <TextBlock
                                x:Name="ImmediateQueueEmptyText"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Center"
                                Opacity="0.6"
                                Text="No urgent threads right now."
                                Visibility="Collapsed" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border
                Grid.Column="1"
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontWeight="SemiBold" Text="Branch workspace kanban" />
                    <TabView
                        x:Name="BranchWorkspaceTabs"
                        Grid.Row="1"
                        TabWidthMode="SizeToContent"
                        CanDragTabs="False"
                        CanReorderTabs="False"
                        IsAddTabButtonVisible="False"
                        SelectionChanged="BranchWorkspaceTabs_SelectionChanged" />
                    <Grid Grid.Row="2" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock FontSize="12" FontWeight="SemiBold" Text="New inquiries" />
                            <ScrollViewer MaxHeight="420" VerticalScrollBarVisibility="Auto">
                                <ItemsControl
                                    x:Name="NewInquiriesItems"
                                    ItemTemplate="{StaticResource UnifiedMessengerKanbanCardTemplate}" />
                            </ScrollViewer>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock FontSize="12" FontWeight="SemiBold" Text="Hanging leads" />
                            <ScrollViewer MaxHeight="420" VerticalScrollBarVisibility="Auto">
                                <ItemsControl
                                    x:Name="HangingLeadsItems"
                                    ItemTemplate="{StaticResource UnifiedMessengerKanbanCardTemplate}" />
                            </ScrollViewer>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="6">
                            <TextBlock FontSize="12" FontWeight="SemiBold" Text="Resolved" />
                            <ScrollViewer MaxHeight="420" VerticalScrollBarVisibility="Auto">
                                <ItemsControl
                                    x:Name="ResolvedItems"
                                    ItemTemplate="{StaticResource UnifiedMessengerKanbanCardTemplate}" />
                            </ScrollViewer>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
