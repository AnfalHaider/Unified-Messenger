<?xml version="1.0" encoding="utf-8" ?>
<Grid
    x:Class="UnifiedMessenger.Controls.WorkspaceSidebar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    mc:Ignorable="d">

    <Grid.RowDefinitions>
        <RowDefinition Height="*" MinHeight="0" />
        <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <ScrollViewer
        Grid.Row="0"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="MenuRoot" Padding="8,12,8,8" Spacing="2">
            <StackPanel
                x:Name="BrandHeaderPanel"
                Margin="4,0,4,12"
                Orientation="Horizontal"
                Spacing="10">
                <Image
                    Width="24"
                    Height="24"
                    Source="Assets/AppIcon.ico" />
                <TextBlock
                    x:Name="BrandTitleText"
                    VerticalAlignment="Center"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Text="Unified Messenger" />
            </StackPanel>

            <StackPanel x:Name="MenuStack" Spacing="2" />
        </StackPanel>
    </ScrollViewer>

    <StackPanel
        Grid.Row="1"
        x:Name="FooterPanel"
        Padding="12,10,12,12"
        Spacing="8"
        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
        BorderThickness="0,1,0,0">
        <Button
            x:Name="AddInstanceButton"
            HorizontalAlignment="Stretch"
            Click="AddInstanceButton_Click"
            Style="{StaticResource AccentButtonStyle}"
            ToolTipService.ToolTip="Add Instance">
            <StackPanel x:Name="AddInstanceContent" Orientation="Horizontal" Spacing="8">
                <FontIcon FontSize="14" Glyph="&#xE710;" />
                <TextBlock x:Name="AddInstanceLabel" Text="Add Instance" />
            </StackPanel>
        </Button>

        <Button
            x:Name="NotificationsButton"
            HorizontalAlignment="Stretch"
            Click="NotificationsButton_Click"
            Style="{StaticResource SubtleButtonStyle}"
            ToolTipService.ToolTip="Notification Hub">
            <Grid x:Name="NotificationsContent" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <FontIcon
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="14"
                    Glyph="&#xEA8F;" />
                <TextBlock
                    x:Name="NotificationsLabel"
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Text="Notification Hub" />
                <InfoBadge
                    x:Name="NotificationHubBadge"
                    Grid.Column="2"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    Visibility="Collapsed" />
            </Grid>
        </Button>

        <Button
            x:Name="SettingsButton"
            HorizontalAlignment="Stretch"
            Click="SettingsButton_Click"
            Style="{StaticResource SubtleButtonStyle}"
            ToolTipService.ToolTip="Settings">
            <StackPanel x:Name="SettingsContent" Orientation="Horizontal" Spacing="10">
                <FontIcon FontSize="14" Glyph="&#xE713;" />
                <TextBlock x:Name="SettingsLabel" Text="Settings" />
            </StackPanel>
        </Button>
    </StackPanel>
</Grid>
