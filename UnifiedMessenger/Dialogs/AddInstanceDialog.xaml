<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="UnifiedMessenger.Dialogs.AddInstanceDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    DefaultButton="Primary"
    PrimaryButtonText="Add"
    SecondaryButtonText="Cancel"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
    Title="Add account"
    AutomationProperties.Name="Add account">

    <StackPanel MinWidth="360" Spacing="12" TabFocusNavigation="Cycle">
        <ComboBox
            x:Name="RestoreBox"
            Header="Restore removed account (optional)"
            DisplayMemberPath="DisplayName"
            SelectionChanged="RestoreBox_SelectionChanged"
            Visibility="Collapsed" />

        <TextBox
            x:Name="DisplayNameBox"
            Header="Display name"
            PlaceholderText="e.g. WhatsApp Work" />

        <ComboBox
            x:Name="PlatformBox"
            Header="Platform"
            SelectionChanged="PlatformBox_SelectionChanged" />

        <ComboBox
            x:Name="CategoryBox"
            Header="Workspace"
            SelectionChanged="CategoryBox_SelectionChanged" />

        <TextBox
            x:Name="CustomUrlBox"
            Header="Website URL"
            PlaceholderText="https://example.com"
            Visibility="Collapsed" />

        <TextBlock
            x:Name="ValidationMessage"
            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
            TextWrapping="WrapWholeWords"
            Visibility="Collapsed" />
    </StackPanel>
</ContentDialog>
