<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="UnifiedMessenger.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:UnifiedMessenger.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UnifiedMessenger"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Unified Messenger"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Title="Unified Messenger"
            IsBackButtonVisible="False"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="TitleBar_PaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
            <TitleBar.RightHeader>
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <ComboBox
                        x:Name="ScopeSelector"
                        MinWidth="128"
                        AutomationProperties.Name="Account scope"
                        SelectionChanged="ScopeSelector_SelectionChanged"
                        ToolTipService.ToolTip="Filter accounts by scope"
                        Visibility="Collapsed">
                        <ComboBoxItem Content="All accounts" Tag="All" />
                        <ComboBoxItem Content="Professional" Tag="Professional" />
                        <ComboBoxItem Content="Personal" Tag="Personal" />
                    </ComboBox>
                    <ToggleButton
                        x:Name="AiToggleButton"
                        AutomationProperties.Name="Toggle on-device AI insights"
                        Click="AiToggleButton_Click"
                        ToolTipService.ToolTip="On-device AI insights (Ollama). Falls back to heuristics when off or unavailable.">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="14" Glyph="&#xE945;" />
                            <TextBlock Text="AI" />
                        </StackPanel>
                    </ToggleButton>
                    <Button
                        x:Name="PanePinButton"
                        Click="PanePinButton_Click"
                        ToolTipService.ToolTip="Pin sidebar expanded">
                        <FontIcon x:Name="PanePinIcon" Glyph="&#xE718;" />
                    </Button>
                    <Button
                        x:Name="NotificationToggleButton"
                        AutomationProperties.AutomationId="ShellNotificationToggle"
                        AutomationProperties.Name="Toggle notification panel"
                        Click="NotificationToggleButton_Click"
                        ToolTipService.ToolTip="Toggle notification panel">
                        <FontIcon Glyph="&#xEA8F;" />
                    </Button>
                </StackPanel>
            </TitleBar.RightHeader>
        </TitleBar>

        <Grid Grid.Row="1" x:Name="ShellLayoutGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="320" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="NotificationColumn" Width="0" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition x:Name="NotificationRow" Height="0" />
            </Grid.RowDefinitions>

            <Border
                x:Name="SidebarHost"
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0"
                PointerEntered="SidebarHost_PointerEntered"
                PointerExited="SidebarHost_PointerExited">
                <controls:WorkspaceSidebar x:Name="WorkspaceSidebar" />
            </Border>

            <Grid Grid.Row="0" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Instance top bar — a docked "Back to dashboard" for EVERY open account, plus a browser
                     toolbar (NavControlsPanel) for embedded / custom-URL tabs. Docked (not overlaid) so it
                     never covers the page. Wired to the active WebView in MainWindow.xaml.cs. -->
                <Border
                    x:Name="WebNavBar"
                    Grid.Row="0"
                    Padding="8,6"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1"
                    Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <HyperlinkButton
                            x:Name="BackToDashboardButton"
                            Click="BackToDashboardButton_Click"
                            AutomationProperties.Name="Back to dashboard"
                            ToolTipService.ToolTip="Back to dashboard">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="12" Glyph="&#xE72B;" />
                                <TextBlock Text="Dashboard" />
                            </StackPanel>
                        </HyperlinkButton>

                        <StackPanel x:Name="NavControlsPanel" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <Border Width="1" Height="22" Margin="2,0,4,0" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                            <Button x:Name="NavBackButton" Click="NavBackButton_Click" Style="{StaticResource SubtleButtonStyle}" Padding="8" AutomationProperties.Name="Back" ToolTipService.ToolTip="Back">
                                <FontIcon FontSize="14" Glyph="&#xE72B;" />
                            </Button>
                            <Button x:Name="NavForwardButton" Click="NavForwardButton_Click" Style="{StaticResource SubtleButtonStyle}" Padding="8" AutomationProperties.Name="Forward" ToolTipService.ToolTip="Forward">
                                <FontIcon FontSize="14" Glyph="&#xE72A;" />
                            </Button>
                            <Button x:Name="NavReloadButton" Click="NavReloadButton_Click" Style="{StaticResource SubtleButtonStyle}" Padding="8" AutomationProperties.Name="Reload" ToolTipService.ToolTip="Reload">
                                <FontIcon FontSize="14" Glyph="&#xE72C;" />
                            </Button>
                            <Button x:Name="NavHomeButton" Click="NavHomeButton_Click" Style="{StaticResource SubtleButtonStyle}" Padding="8" AutomationProperties.Name="Home" ToolTipService.ToolTip="Home — back to this account's start page">
                                <FontIcon FontSize="14" Glyph="&#xE80F;" />
                            </Button>
                            <Border
                                Margin="4,0,0,0"
                                Padding="10,0"
                                Height="32"
                                MinWidth="200"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                    <FontIcon FontSize="12" Glyph="&#xE72E;" Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                                    <TextBlock x:Name="NavAddressText" VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1">
                <Grid x:Name="InstanceWebViewHost" />

                <StackPanel
                    x:Name="InstanceLoadingPanel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12"
                    Visibility="Collapsed">
                    <ProgressRing
                        x:Name="InstanceLoadingRing"
                        Width="40"
                        Height="40"
                        Foreground="{StaticResource UmBrandBlueBrush}"
                        IsActive="True" />
                    <ProgressBar
                        x:Name="StartupWarmProgressBar"
                        Width="280"
                        Maximum="1"
                        Visibility="Collapsed" />
                    <TextBlock
                        x:Name="InstanceLoadingText"
                        HorizontalAlignment="Center"
                        Opacity="0.8"
                        Text="Loading instance..." />
                </StackPanel>

                <Frame
                    x:Name="ContentFrame"
                    Visibility="Collapsed" />
                </Grid>
            </Grid>

            <controls:NotificationFeedPanel
                x:Name="NotificationPanel"
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="2"
                Visibility="Collapsed" />

        </Grid>

        <controls:CommandPalette
            x:Name="CommandPaletteOverlay"
            Grid.RowSpan="2"
            ItemSelected="CommandPaletteOverlay_ItemSelected" />
    </Grid>
</Window>
