<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="UnifiedMessenger.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UnifiedMessenger.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24,16,24,32" Spacing="18" MaxWidth="680">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <HyperlinkButton
                    AutomationProperties.Name="Back to Settings"
                    Click="SettingsBreadcrumb_Click"
                    Content="Settings" />
                <TextBlock VerticalAlignment="Center" Opacity="0.65" Text="›" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Text="About" />
            </StackPanel>

            <!-- Hero: app logo, name + version, value badges, and the update action. -->
            <Border
                Padding="28,32,28,28"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel HorizontalAlignment="Center" Spacing="14">
                    <!-- Brand logo: the 1024px RGBA master PNG renders reliably in Image (a multi-frame .ico
                         does not) and is transparent, so it needs no backing tile. -->
                    <Image
                        Width="112"
                        Height="112"
                        HorizontalAlignment="Center"
                        Source="Assets/Branding/icon-master.png" />

                    <TextBlock
                        x:Name="VersionText"
                        HorizontalAlignment="Center"
                        FontSize="20"
                        FontWeight="SemiBold" />

                    <TextBlock
                        HorizontalAlignment="Center"
                        MaxWidth="440"
                        FontSize="15"
                        Opacity="0.8"
                        Text="WhatsApp operations in one native workspace."
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords" />

                    <StackPanel
                        Margin="0,2,0,0"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="12" Padding="11,4">
                            <TextBlock FontSize="12" Opacity="0.9" Text="100% local" />
                        </Border>
                        <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="12" Padding="11,4">
                            <TextBlock FontSize="12" Opacity="0.9" Text="No cloud" />
                        </Border>
                    </StackPanel>

                    <Button
                        x:Name="CheckForUpdatesButton"
                        Margin="0,6,0,0"
                        HorizontalAlignment="Center"
                        Click="CheckForUpdatesButton_Click"
                        Content="Check for updates"
                        Style="{StaticResource AccentButtonStyle}" />
                </StackPanel>
            </Border>

            <!-- What it does -->
            <Border
                Padding="22"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel Spacing="10">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="What it does" />
                    <TextBlock
                        Opacity="0.85"
                        Text="Unified Messenger runs multiple isolated WhatsApp and WhatsApp Business Web sessions in a single WinUI desktop shell, with a unified notification hub and an operations dashboard. The command center tracks response metrics, branch workload, and message volume over selectable date ranges — all on this machine, with no cloud dependency."
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <!-- Key features -->
            <Border
                Padding="22"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel Spacing="14">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Key features" />

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon
                            Glyph="&#xE73E;"
                            FontSize="16"
                            Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                            VerticalAlignment="Top" />
                        <TextBlock
                            Opacity="0.85"
                            Text="Multi-profile isolation — each account is its own logged-in WhatsApp session in a shared, optimized WebView2 environment."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon
                            Glyph="&#xE73E;"
                            FontSize="16"
                            Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                            VerticalAlignment="Top" />
                        <TextBlock
                            Opacity="0.85"
                            Text="Unified notification feed that navigates straight to the right account and chat."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon
                            Glyph="&#xE73E;"
                            FontSize="16"
                            Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                            VerticalAlignment="Top" />
                        <TextBlock
                            Opacity="0.85"
                            Text="Needs-reply oversight, KPI dashboard, and date-filtered analytics — no cloud LLM dependency."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
