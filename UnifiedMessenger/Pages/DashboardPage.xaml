<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="UnifiedMessenger.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:UnifiedMessenger.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="8">
            <TextBlock
                x:Name="WelcomeTitle"
                Style="{StaticResource TitleTextBlockStyle}"
                Text="Welcome back" />
            <TextBlock
                x:Name="WelcomeSubtitle"
                Opacity="0.7"
                Text="Your unified messaging workspace"
                TextWrapping="WrapWholeWords" />
        </StackPanel>

        <TabView
            x:Name="DashboardTabs"
            Grid.Row="1"
            TabWidthMode="Equal"
            CanDragTabs="False"
            CanReorderTabs="False"
            IsAddTabButtonVisible="False">
            <TabViewItem Header="Professional Operations" IsClosable="False">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid MinHeight="360">
                        <Grid
                            x:Name="ProfessionalContentGrid"
                            RowSpacing="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                        <!-- KPI metrics -->
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Padding="16"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Spacing="6">
                                    <TextBlock FontSize="11" Opacity="0.65" Text="Average reply time" />
                                    <TextBlock
                                        x:Name="AvgReplyTimeValue"
                                        FontSize="24"
                                        FontWeight="SemiBold"
                                        Text="—" />
                                </StackPanel>
                            </Border>
                            <Border
                                Grid.Column="1"
                                Padding="16"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Spacing="6">
                                    <TextBlock FontSize="11" Opacity="0.65" Text="SLA breaches" />
                                    <TextBlock
                                        x:Name="SlaBreachesValue"
                                        FontSize="24"
                                        FontWeight="SemiBold"
                                        Text="0" />
                                </StackPanel>
                            </Border>
                            <Border
                                Grid.Column="2"
                                Padding="16"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Spacing="6">
                                    <TextBlock FontSize="11" Opacity="0.65" Text="Response rate" />
                                    <TextBlock
                                        x:Name="ResponseRateValue"
                                        FontSize="24"
                                        FontWeight="SemiBold"
                                        Text="—" />
                                </StackPanel>
                            </Border>
                            <Border
                                Grid.Column="3"
                                Padding="16"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Spacing="6">
                                    <TextBlock FontSize="11" Opacity="0.65" Text="Peak hour · Daily trend" />
                                    <TextBlock
                                        x:Name="PeakHourValue"
                                        FontSize="20"
                                        FontWeight="SemiBold"
                                        Text="—" />
                                    <TextBlock
                                        x:Name="DailyTrendValue"
                                        FontSize="11"
                                        Opacity="0.55"
                                        Text="—" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Enterprise workspace widgets -->
                        <Grid Grid.Row="1" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Padding="16"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Spacing="12">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="4">
                                            <TextBlock FontWeight="SemiBold" Text="Customer Trust Card" />
                                            <TextBlock
                                                FontSize="12"
                                                Opacity="0.65"
                                                Text="Google Business review alerts across professional locations"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="2">
                                            <TextBlock
                                                FontSize="11"
                                                Opacity="0.6"
                                                Text="Aggregate rating" />
                                            <TextBlock
                                                x:Name="AggregateRatingValue"
                                                FontSize="20"
                                                FontWeight="SemiBold"
                                                HorizontalAlignment="Right"
                                                Text="—" />
                                            <TextBlock
                                                x:Name="UnrepliedReviewsValue"
                                                FontSize="11"
                                                Opacity="0.55"
                                                HorizontalAlignment="Right"
                                                Text="0 unreplied" />
                                        </StackPanel>
                                    </Grid>

                                    <ListView
                                        x:Name="GoogleReviewAlertsList"
                                        MaxHeight="180"
                                        SelectionChanged="GoogleReviewAlertsList_SelectionChanged"
                                        SelectionMode="Single">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="8,6" ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock
                                                        VerticalAlignment="Top"
                                                        FontWeight="SemiBold"
                                                        Foreground="#4285F4"
                                                        Text="{Binding RatingDisplay}" />
                                                    <StackPanel Grid.Column="1" Spacing="2">
                                                        <Grid ColumnSpacing="8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock
                                                                FontWeight="SemiBold"
                                                                Text="{Binding ReviewerName}"
                                                                TextTrimming="CharacterEllipsis" />
                                                            <TextBlock
                                                                Grid.Column="1"
                                                                FontSize="11"
                                                                Opacity="0.55"
                                                                Text="{Binding RelativeTimeText}" />
                                                        </Grid>
                                                        <TextBlock
                                                            FontSize="12"
                                                            Opacity="0.75"
                                                            Text="{Binding Snippet}"
                                                            TextTrimming="CharacterEllipsis"
                                                            TextWrapping="WrapWholeWords"
                                                            MaxLines="2" />
                                                        <TextBlock
                                                            FontSize="11"
                                                            Opacity="0.55"
                                                            Text="{Binding LocationLabel}" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>

                                    <TextBlock
                                        x:Name="GoogleReviewAlertsEmptyText"
                                        Opacity="0.6"
                                        Text="Connect a Google Business Profile professional instance to track unreplied reviews."
                                        TextWrapping="WrapWholeWords"
                                        Visibility="Collapsed" />

                                    <TextBox
                                        x:Name="ReviewReplyBox"
                                        AcceptsReturn="True"
                                        PlaceholderText="Draft a native reply to the selected review..."
                                        TextWrapping="Wrap"
                                        MaxHeight="96" />

                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button
                                            x:Name="SubmitReviewReplyButton"
                                            Click="SubmitReviewReplyButton_Click"
                                            Content="Open location &amp; reply" />
                                        <Button
                                            Click="OpenSelectedReviewInstanceButton_Click"
                                            Content="Open Google Business" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border
                                Grid.Column="1"
                                Padding="16"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Spacing="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock FontWeight="SemiBold" Text="Response Time Analytics" />
                                        <TextBlock
                                            FontSize="12"
                                            Opacity="0.65"
                                            Text="Meta Business Suite first-response efficiency across professional inboxes"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Padding="12"
                                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                                            CornerRadius="6">
                                            <StackPanel Spacing="4">
                                                <TextBlock FontSize="11" Opacity="0.6" Text="Average response" />
                                                <TextBlock
                                                    x:Name="MetaAverageResponseValue"
                                                    FontSize="24"
                                                    FontWeight="SemiBold"
                                                    Text="—" />
                                            </StackPanel>
                                        </Border>
                                        <Border
                                            Grid.Column="1"
                                            Padding="12"
                                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                                            CornerRadius="6">
                                            <StackPanel Spacing="4">
                                                <TextBlock FontSize="11" Opacity="0.6" Text="Efficiency rating" />
                                                <TextBlock
                                                    x:Name="MetaEfficiencyRatingValue"
                                                    FontSize="20"
                                                    FontWeight="SemiBold"
                                                    Text="Awaiting data" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="2">
                                            <TextBlock FontSize="11" Opacity="0.6" Text="Samples logged" />
                                            <TextBlock
                                                x:Name="MetaSampleCountValue"
                                                FontWeight="SemiBold"
                                                Text="0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock FontSize="11" Opacity="0.6" Text="Last inbound" />
                                            <TextBlock
                                                x:Name="MetaLastInboundValue"
                                                FontWeight="SemiBold"
                                                Text="—" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Spacing="2">
                                            <TextBlock FontSize="11" Opacity="0.6" Text="Last reply" />
                                            <TextBlock
                                                x:Name="MetaLastReplyValue"
                                                FontWeight="SemiBold"
                                                Text="—" />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock
                                        x:Name="MetaResponseEmptyText"
                                        FontSize="12"
                                        Opacity="0.6"
                                        Text="Add a Meta Business Suite professional instance to begin measuring response efficiency."
                                        TextWrapping="WrapWholeWords"
                                        Visibility="Collapsed" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- 7-day activity chart -->
                        <Border
                            Grid.Row="2"
                            MinHeight="200"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="8">
                                <Grid ColumnSpacing="24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock FontWeight="SemiBold" Text="Message volume" />
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock FontSize="11" Opacity="0.6" Text="Sent total" />
                                        <TextBlock
                                            x:Name="SentCountValue"
                                            FontSize="18"
                                            FontWeight="SemiBold"
                                            Text="0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="2">
                                        <TextBlock FontSize="11" Opacity="0.6" Text="Received total" />
                                        <TextBlock
                                            x:Name="ReceivedCountValue"
                                            FontSize="18"
                                            FontWeight="SemiBold"
                                            Text="0" />
                                    </StackPanel>
                                    <Button
                                        Grid.Column="3"
                                        VerticalAlignment="Bottom"
                                        Click="ExportAnalyticsButton_Click"
                                        Content="Export analytics" />
                                </Grid>
                                <controls:WeeklyActivityChart x:Name="WeeklyChart" />
                            </StackPanel>
                        </Border>

                        <!-- Operational highlights -->
                        <Border
                            Grid.Row="3"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock FontWeight="SemiBold" Text="Operational Highlights" />
                                <ListView
                                    x:Name="OperationalHighlightsList"
                                    Grid.Row="1"
                                    IsItemClickEnabled="True"
                                    ItemClick="OperationalHighlightsList_ItemClick"
                                    MaxHeight="280"
                                    SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="8,10" ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon
                                                    VerticalAlignment="Top"
                                                    FontSize="14"
                                                    Glyph="&#xE735;"
                                                    Opacity="0.75" />
                                                <StackPanel Grid.Column="1" Spacing="2">
                                                    <TextBlock
                                                        FontWeight="SemiBold"
                                                        Text="{Binding Title}"
                                                        TextTrimming="CharacterEllipsis" />
                                                    <TextBlock
                                                        FontSize="12"
                                                        Opacity="0.7"
                                                        Text="{Binding Subtitle}" />
                                                    <TextBlock
                                                        FontSize="11"
                                                        Opacity="0.55"
                                                        Text="{Binding InstanceDisplayName}" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <TextBlock
                                    x:Name="OperationalHighlightsEmptyText"
                                    Grid.Row="1"
                                    Opacity="0.6"
                                    Text="Pinned business threads from professional accounts will appear here."
                                    TextWrapping="WrapWholeWords"
                                    Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        </Grid>

                        <Border
                            x:Name="ProfessionalEmptyPanel"
                            Padding="32,48"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="Collapsed">
                            <StackPanel
                                MaxWidth="420"
                                HorizontalAlignment="Center"
                                Spacing="12">
                                <FontIcon
                                    HorizontalAlignment="Center"
                                    FontSize="40"
                                    Glyph="&#xE731;"
                                    Opacity="0.45" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="No professional accounts yet"
                                    TextAlignment="Center" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    Opacity="0.7"
                                    Text="Add an instance with Workspace set to Professional, or right-click an existing account in the sidebar and move it to the Professional workspace."
                                    TextAlignment="Center"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="Personal Overview" IsClosable="False">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <AutoSuggestBox
                            x:Name="GlobalSearchBox"
                            PlaceholderText="Search personal accounts, senders, or messages..."
                            QueryIcon="Find"
                            QuerySubmitted="GlobalSearchBox_QuerySubmitted"
                            SuggestionChosen="GlobalSearchBox_SuggestionChosen"
                            TextChanged="GlobalSearchBox_TextChanged" />

                        <Grid
                            x:Name="ContentGrid"
                            Grid.Row="1"
                            ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="LeftColumn" Width="*" MinWidth="280" />
                                <ColumnDefinition x:Name="RightColumn" Width="*" MinWidth="260" />
                            </Grid.ColumnDefinitions>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup>
                                    <VisualState x:Name="WideLayout">
                                        <VisualState.StateTriggers>
                                            <AdaptiveTrigger MinWindowWidth="860" />
                                        </VisualState.StateTriggers>
                                        <VisualState.Setters>
                                            <Setter Target="LeftColumn.(Grid.Column)" Value="0" />
                                            <Setter Target="LeftColumn.(Grid.Row)" Value="0" />
                                            <Setter Target="RightColumn.(Grid.Column)" Value="1" />
                                            <Setter Target="RightColumn.(Grid.Row)" Value="0" />
                                            <Setter Target="LeftColumn.(Grid.ColumnSpan)" Value="1" />
                                            <Setter Target="RightColumn.(Grid.ColumnSpan)" Value="1" />
                                            <Setter Target="ContentGrid.RowDefinitions[0].Height" Value="Auto" />
                                            <Setter Target="ContentGrid.RowDefinitions[1].Height" Value="0" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="NarrowLayout">
                                        <VisualState.Setters>
                                            <Setter Target="LeftColumn.(Grid.Column)" Value="0" />
                                            <Setter Target="LeftColumn.(Grid.Row)" Value="0" />
                                            <Setter Target="RightColumn.(Grid.Column)" Value="0" />
                                            <Setter Target="RightColumn.(Grid.Row)" Value="1" />
                                            <Setter Target="LeftColumn.(Grid.ColumnSpan)" Value="2" />
                                            <Setter Target="RightColumn.(Grid.ColumnSpan)" Value="2" />
                                            <Setter Target="ContentGrid.RowDefinitions[0].Height" Value="Auto" />
                                            <Setter Target="ContentGrid.RowSpacing" Value="16" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border
                                MinHeight="200"
                                Padding="16"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <Grid RowSpacing="12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" MinHeight="120" />
                                    </Grid.RowDefinitions>
                                    <TextBlock FontWeight="SemiBold" Text="Recent Activity" />
                                    <ListView
                                        x:Name="RecentActivityList"
                                        Grid.Row="1"
                                        IsItemClickEnabled="True"
                                        ItemClick="RecentActivityList_ItemClick"
                                        MaxHeight="420"
                                        SelectionMode="None">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="8,10" ColumnSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <FontIcon
                                                        VerticalAlignment="Top"
                                                        FontSize="14"
                                                        Foreground="{Binding AccentBrush}"
                                                        Glyph="{Binding IconGlyph}" />
                                                    <StackPanel Grid.Column="1" Spacing="2">
                                                        <Grid ColumnSpacing="8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock
                                                                FontWeight="SemiBold"
                                                                Text="{Binding Title}"
                                                                TextTrimming="CharacterEllipsis" />
                                                            <TextBlock
                                                                Grid.Column="1"
                                                                FontSize="11"
                                                                Opacity="0.55"
                                                                Text="{Binding RelativeTimeText}" />
                                                        </Grid>
                                                        <TextBlock
                                                            FontSize="12"
                                                            Opacity="0.75"
                                                            Text="{Binding Body}"
                                                            TextTrimming="CharacterEllipsis" />
                                                        <TextBlock
                                                            FontSize="11"
                                                            Opacity="0.55"
                                                            Text="{Binding InstanceDisplayName}" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                    <TextBlock
                                        x:Name="RecentActivityEmptyText"
                                        Grid.Row="1"
                                        Opacity="0.6"
                                        Text="No recent notifications from personal accounts."
                                        TextWrapping="WrapWholeWords"
                                        Visibility="Collapsed" />
                                </Grid>
                            </Border>

                            <Border
                                Grid.Column="1"
                                Padding="16"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Spacing="12">
                                    <TextBlock FontWeight="SemiBold" Text="Performance &amp; Resources" />

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Padding="12"
                                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                                            CornerRadius="6">
                                            <StackPanel Spacing="4">
                                                <TextBlock
                                                    FontSize="11"
                                                    Opacity="0.6"
                                                    Text="Personal accounts" />
                                                <TextBlock
                                                    x:Name="ActiveAccountsValue"
                                                    FontSize="22"
                                                    FontWeight="SemiBold"
                                                    Text="0" />
                                            </StackPanel>
                                        </Border>
                                        <Border
                                            Grid.Column="1"
                                            Padding="12"
                                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                                            CornerRadius="6">
                                            <StackPanel Spacing="4">
                                                <TextBlock
                                                    FontSize="11"
                                                    Opacity="0.6"
                                                    Text="Memory (working set)" />
                                                <TextBlock
                                                    x:Name="MemoryValue"
                                                    FontSize="22"
                                                    FontWeight="SemiBold"
                                                    Text="0 MB" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Padding="12"
                                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                                            CornerRadius="6">
                                            <StackPanel Spacing="4">
                                                <TextBlock
                                                    FontSize="11"
                                                    Opacity="0.6"
                                                    Text="Personal unread" />
                                                <TextBlock
                                                    x:Name="UnreadValue"
                                                    FontSize="22"
                                                    FontWeight="SemiBold"
                                                    Text="0" />
                                            </StackPanel>
                                        </Border>
                                        <Border
                                            Grid.Column="1"
                                            Padding="12"
                                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                                            CornerRadius="6">
                                            <StackPanel Spacing="4">
                                                <TextBlock
                                                    FontSize="11"
                                                    Opacity="0.6"
                                                    Text="Visible account" />
                                                <TextBlock
                                                    x:Name="VisibleAccountValue"
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    Text="None"
                                                    TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="Personal account status"
                                        TextWrapping="WrapWholeWords" />
                                    <ListView
                                        x:Name="InstanceTilesList"
                                        IsItemClickEnabled="True"
                                        ItemClick="InstanceTilesList_ItemClick"
                                        SelectionMode="None">
                                        <ListView.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <ItemsWrapGrid MaximumRowsOrColumns="2" Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ListView.ItemsPanel>
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Width="148"
                                                    Margin="0,0,8,8"
                                                    Padding="10"
                                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                    BorderBrush="{Binding AccentBrush}"
                                                    BorderThickness="2,0,0,0"
                                                    CornerRadius="6">
                                                    <StackPanel Spacing="4">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <FontIcon
                                                                FontSize="12"
                                                                Foreground="{Binding AccentBrush}"
                                                                Glyph="{Binding IconGlyph}" />
                                                            <TextBlock
                                                                FontWeight="SemiBold"
                                                                Text="{Binding DisplayName}"
                                                                TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                        <TextBlock
                                                            FontSize="11"
                                                            Opacity="0.6"
                                                            Text="{Binding PlatformLabel}" />
                                                        <TextBlock FontSize="11" Text="{Binding StatusLine}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </TabViewItem>
        </TabView>
    </Grid>
</Page>
