<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="UnifiedMessenger.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:UnifiedMessenger.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:DataType="local:DashboardPage"
    xmlns:local="using:UnifiedMessenger.Pages">

    <ScrollViewer
        x:Name="DashboardScrollViewer"
        Padding="24,20"
        VerticalScrollBarVisibility="Auto"
        HorizontalScrollMode="Disabled">
        <StackPanel Spacing="16" HorizontalAlignment="Stretch">
            <!-- Header: greeting + a "Personal" button (top) that opens the personal overview in a flyout. -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="4" VerticalAlignment="Center">
                    <TextBlock
                        x:Name="WelcomeTitle"
                        AutomationProperties.Name="Welcome back"
                        Style="{StaticResource TitleTextBlockStyle}"
                        Text="Welcome back" />
                    <TextBlock
                        x:Name="WelcomeSubtitle"
                        Opacity="0.7"
                        Text="Your unified messaging workspace"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Button
                    x:Name="PersonalButton"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    AutomationProperties.AutomationId="DashboardPersonalOverviewButton"
                    AutomationProperties.Name="Personal overview"
                    ToolTipService.ToolTip="Personal accounts overview">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="16" Glyph="&#xE716;" />
                        <TextBlock x:Name="PersonalButtonLabel" Text="Personal" />
                    </StackPanel>
                    <Button.Flyout>
                        <Flyout x:Name="PersonalFlyout" Placement="Bottom" Opened="PersonalFlyout_Opened">
                            <Flyout.FlyoutPresenterStyle>
                                <Style TargetType="FlyoutPresenter">
                                    <Setter Property="MaxWidth" Value="760" />
                                    <Setter Property="MaxHeight" Value="580" />
                                    <Setter Property="Padding" Value="12" />
                                    <Setter Property="CornerRadius" Value="10" />
                                </Style>
                            </Flyout.FlyoutPresenterStyle>
                            <controls:PersonalOverviewPanel
                                x:Name="PersonalOverviewPanel"
                                Width="660"
                                MaxHeight="540" />
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </Grid>

            <controls:CommandCenterPanel x:Name="CommandCenterPanel" />

            <controls:ActivityPatternsPanel x:Name="ActivityPatternsPanel" />

            <controls:ReviewHealthPanel x:Name="ReviewHealthPanel" />
        </StackPanel>
    </ScrollViewer>
</Page>
