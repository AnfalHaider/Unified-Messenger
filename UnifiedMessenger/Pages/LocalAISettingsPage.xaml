<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="UnifiedMessenger.Pages.LocalAISettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:vm="using:UnifiedMessenger.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24,16,24,24" Spacing="20" MaxWidth="720">
            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <HyperlinkButton
                        AutomationProperties.Name="Back to Settings"
                        Click="SettingsBreadcrumb_Click"
                        Content="Settings" />
                    <TextBlock VerticalAlignment="Center" Opacity="0.65" Text="›" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="Local AI" />
                </StackPanel>
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" AutomationProperties.Name="Local AI" Text="Local AI" />
                <TextBlock
                    Opacity="0.7"
                    Text="Run models locally with Ollama for private drafting and dashboard triage."
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <Border
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Ellipse
                        x:Name="ConnectionIndicator"
                        Width="10"
                        Height="10"
                        VerticalAlignment="Center"
                        Fill="{ThemeResource SystemFillColorCautionBrush}" />

                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                        <TextBlock
                            x:Name="ConnectionTitleText"
                            FontWeight="SemiBold"
                            Text="Engine status" />
                        <TextBlock
                            x:Name="ConnectionDetailText"
                            FontSize="12"
                            Opacity="0.75"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Click="RefreshEngineButton_Click"
                        Content="Refresh" />
                </Grid>
            </Border>

            <StackPanel Spacing="8">
                <TextBlock
                    FontWeight="SemiBold"
                    Opacity="0.75"
                    Text="GENERAL" />
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <ToggleSwitch
                            x:Name="EnableLocalAiToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="EnableLocalAiToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Enable local AI" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="Uses Ollama on this PC. No message text is sent to the cloud when enabled."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="OllamaAutoBootstrapToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="OllamaAutoBootstrapToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Install Ollama automatically" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="Downloads the official Windows CLI into AppData when the engine is missing (~2 GB)."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ComboBox
                            x:Name="DefaultModelBox"
                            Header="Default model for drafting"
                            SelectionChanged="DefaultModelBox_SelectionChanged" />

                        <ToggleSwitch
                            x:Name="EnableBranchPulseToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="EnableBranchPulseToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Branch pulse summaries" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="Batch-summarize open threads per branch in the Operations Command Center."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="EnableAutoDraftToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="EnableAutoDraftToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Auto-draft replies (human review required)" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="Fills the compose box only. Unified Messenger never sends messages automatically."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="AutoDraftOnlyVisibleToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="AutoDraftOnlyVisibleToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Draft only for the visible workspace" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="When on, background instances will not receive AI drafts."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ComboBox
                            x:Name="DraftToneBox"
                            Header="WhatsApp draft tone"
                            SelectionChanged="DraftToneBox_SelectionChanged" />

                        <ToggleSwitch
                            x:Name="EnableVoiceNoteTranscriptionToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="EnableVoiceNoteTranscriptionToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Transcribe WhatsApp voice notes" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="Detects incoming voice notes, transcribes locally with whisper.cpp, then runs AI triage on the transcript."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <TextBlock
                            x:Name="WhisperStatusText"
                            FontSize="12"
                            Opacity="0.75"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel
                x:Name="ModelManagerPanel"
                Spacing="8"
                Visibility="Collapsed">
                <TextBlock
                    FontWeight="SemiBold"
                    Opacity="0.75"
                    Text="MODEL DOWNLOAD MANAGER" />
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock
                            FontSize="12"
                            Opacity="0.65"
                            Text="Pull models from the Ollama library. Downloads resume automatically if interrupted."
                            TextWrapping="WrapWholeWords" />

                        <ListView
                            x:Name="ModelsList"
                            IsItemClickEnabled="False"
                            SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:LocalAiModelRowViewModel">
                                    <Border
                                        Margin="0,0,0,12"
                                        Padding="12"
                                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                        <StackPanel Spacing="8">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="2">
                                                    <TextBlock
                                                        FontWeight="SemiBold"
                                                        Text="{x:Bind DisplayName}" />
                                                    <TextBlock
                                                        FontSize="12"
                                                        Opacity="0.65"
                                                        Text="{x:Bind SizeLabel}" />
                                                    <TextBlock
                                                        FontSize="12"
                                                        Opacity="0.55"
                                                        Text="{x:Bind Description}"
                                                        TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                                <Button
                                                    Grid.Column="1"
                                                    VerticalAlignment="Top"
                                                    Click="DownloadModelButton_Click"
                                                    Content="{x:Bind DownloadButtonText}"
                                                    IsEnabled="{x:Bind CanDownload}"
                                                    Tag="{x:Bind ModelId}" />
                                            </Grid>
                                            <ProgressBar
                                                Maximum="100"
                                                Value="{x:Bind Progress, Mode=OneWay}" />
                                            <TextBlock
                                                FontSize="12"
                                                Opacity="0.75"
                                                Text="{x:Bind StatusText, Mode=OneWay}"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
