<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="UnifiedMessenger.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UnifiedMessenger.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24,16,24,24" Spacing="20" MaxWidth="720">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Settings" />

            <StackPanel Spacing="8">
                <TextBlock
                    FontWeight="SemiBold"
                    Opacity="0.75"
                    Text="NOTIFICATIONS" />
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <ToggleSwitch
                            x:Name="BackgroundToastsToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="BackgroundToastsToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Background toast notifications" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="Show Windows toasts when the app is minimized or in the background."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="TaskbarBadgeToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="TaskbarBadgeToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Taskbar badge" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="Show unread count on the taskbar icon."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ComboBox
                            x:Name="PanelAutoOpenBox"
                            Header="Auto-open notification panel"
                            SelectionChanged="PanelAutoOpenBox_SelectionChanged" />

                        <ComboBox
                            x:Name="ToastSoundBox"
                            Header="Toast sound"
                            SelectionChanged="ToastSoundBox_SelectionChanged" />

                        <ToggleSwitch
                            x:Name="IncludeMutedBadgesToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="IncludeMutedBadgesToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Include muted chats in badge counts" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="When off, muted WhatsApp/Telegram chats are excluded from sidebar badges."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="ToastGroupToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="ToastGroupToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Group toasts by instance" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="Stack Windows toasts per account instead of per message."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="ToastBrandingToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="ToastBrandingToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Platform branding in toasts" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="Use instance display name as the toast header line."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <Button
                            HorizontalAlignment="Left"
                            Click="ClearNotificationsButton_Click"
                            Content="Clear notification history" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock
                    FontWeight="SemiBold"
                    Opacity="0.75"
                    Text="APPEARANCE" />
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <ComboBox
                            x:Name="ThemePreferenceBox"
                            Header="App theme"
                            SelectionChanged="ThemePreferenceBox_SelectionChanged" />

                        <ComboBox
                            x:Name="PanelDockBox"
                            Header="Notification panel dock"
                            SelectionChanged="PanelDockBox_SelectionChanged" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock
                    FontWeight="SemiBold"
                    Opacity="0.75"
                    Text="SESSION &amp; PERFORMANCE" />
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <ComboBox
                            x:Name="StartupWarmModeBox"
                            Header="Startup warm mode"
                            SelectionChanged="StartupWarmModeBox_SelectionChanged" />

                        <NumberBox
                            x:Name="MaxConcurrentWebViewsBox"
                            Header="Max concurrent WebViews (0 = unlimited)"
                            Maximum="32"
                            Minimum="0"
                            SpinButtonPlacementMode="Inline"
                            ValueChanged="MaxConcurrentWebViewsBox_ValueChanged" />

                        <Button
                            HorizontalAlignment="Left"
                            Click="RefreshAllWebViewsButton_Click"
                            Content="Refresh all WebViews" />

                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Opacity="0.75"
                            Text="Experimental" />
                        <TextBlock
                            FontSize="12"
                            Opacity="0.65"
                            Text="Path C session options. Behavior may change in future releases."
                            TextWrapping="WrapWholeWords" />

                        <ToggleSwitch
                            x:Name="EnableLazyWebViewLoadingToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="EnableLazyWebViewLoadingToggle_Toggled">
                            <ToggleSwitch.Header>
                                <TextBlock Text="Enable lazy WebView loading" />
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="EnablePerInstanceSleepUnloadToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="EnablePerInstanceSleepUnloadToggle_Toggled">
                            <ToggleSwitch.Header>
                                <TextBlock Text="Enable per-instance sleep unload" />
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="EnableEditInstanceMetadataToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="EnableEditInstanceMetadataToggle_Toggled">
                            <ToggleSwitch.Header>
                                <TextBlock Text="Enable edit instance metadata" />
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="EnableImportExportInstancesToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="EnableImportExportInstancesToggle_Toggled">
                            <ToggleSwitch.Header>
                                <TextBlock Text="Enable import / export instances" />
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <StackPanel
                            x:Name="ImportExportPanel"
                            Spacing="8"
                            Visibility="Collapsed">
                            <Button
                                HorizontalAlignment="Left"
                                Click="ExportInstancesButton_Click"
                                Content="Export instances.json" />
                            <Button
                                HorizontalAlignment="Left"
                                Click="ImportInstancesButton_Click"
                                Content="Import instances.json" />
                        </StackPanel>

                        <ToggleSwitch
                            x:Name="EnableInstanceNotesTagsToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="EnableInstanceNotesTagsToggle_Toggled">
                            <ToggleSwitch.Header>
                                <TextBlock Text="Enable instance notes and tags" />
                            </ToggleSwitch.Header>
                        </ToggleSwitch>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock
                    FontWeight="SemiBold"
                    Opacity="0.75"
                    Text="SYSTEM" />
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <ToggleSwitch
                            x:Name="RunInBackgroundOnCloseToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="RunInBackgroundOnCloseToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Run in background when closing" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="Hide to the system tray instead of quitting. Use tray Quit to exit fully."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="EnableStartupBackfillToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="EnableStartupBackfillToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Enable startup backfill" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="After connect, reconcile unread professional inbox state for triage and dashboard KPIs without replaying notification toasts."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="LaunchAtStartupToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="LaunchAtStartupToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Launch at startup" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="Start Unified Messenger when you sign in to Windows."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="PromptPinToTaskbarToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="PromptPinToTaskbarToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Suggest pin to taskbar" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="Show a one-time prompt to pin Unified Messenger to the taskbar."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="EnableAutoUpdateToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="EnableAutoUpdateToggle_Toggled">
                            <ToggleSwitch.Header>
                                <TextBlock Text="Enable automatic updates" />
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="PromptBeforeAutoUpdateToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="PromptBeforeAutoUpdateToggle_Toggled">
                            <ToggleSwitch.Header>
                                <TextBlock Text="Prompt before auto-update installs" />
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <Button
                            HorizontalAlignment="Left"
                            Click="CheckForUpdatesButton_Click"
                            Content="Check for updates" />

                        <Button
                            HorizontalAlignment="Left"
                            Click="ClearAnalyticsButton_Click"
                            Content="Clear analytics data" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock
                    FontWeight="SemiBold"
                    Opacity="0.75"
                    Text="ANALYTICS" />
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <NumberBox
                            x:Name="SlaThresholdBox"
                            Header="SLA response threshold (minutes)"
                            Maximum="120"
                            Minimum="5"
                            SpinButtonPlacementMode="Inline"
                            ValueChanged="SlaThresholdBox_ValueChanged" />
                        <TextBlock
                            FontSize="12"
                            Opacity="0.65"
                            Text="Replies slower than this count as SLA breaches on the Professional dashboard."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock
                    FontWeight="SemiBold"
                    Opacity="0.75"
                    Text="REMOVED ACCOUNTS" />
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock
                            FontSize="12"
                            Opacity="0.65"
                            Text="Accounts removed from the sidebar keep their login session on disk and can be restored here."
                            TextWrapping="WrapWholeWords" />
                        <ListView
                            x:Name="ArchivedAccountsList"
                            SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:ArchivedAccountItem">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="2" VerticalAlignment="Center">
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind DisplayName}" />
                                            <TextBlock
                                                FontSize="12"
                                                Opacity="0.65"
                                                Text="{x:Bind PlatformLabel}" />
                                        </StackPanel>
                                        <Button
                                            Grid.Column="1"
                                            Click="RestoreAccountButton_Click"
                                            Content="Restore"
                                            Tag="{x:Bind InstanceId}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <TextBlock
                            x:Name="NoArchivedAccountsText"
                            Opacity="0.55"
                            Text="No removed accounts."
                            Visibility="Collapsed" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock
                    FontWeight="SemiBold"
                    Opacity="0.75"
                    Text="STORAGE" />
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock
                            FontSize="12"
                            Opacity="0.65"
                            Text="Instance registry" />
                        <TextBlock
                            x:Name="InstancesPathText"
                            IsTextSelectionEnabled="True"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontSize="12"
                            Opacity="0.65"
                            Text="WebView profiles" />
                        <TextBlock
                            x:Name="ProfilesPathText"
                            IsTextSelectionEnabled="True"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock
                    FontWeight="SemiBold"
                    Opacity="0.75"
                    Text="LOCAL AI" />
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock
                            FontSize="12"
                            Opacity="0.65"
                            Text="Configure Ollama, download models, and choose the default drafting model."
                            TextWrapping="WrapWholeWords" />
                        <HyperlinkButton Click="LocalAiSettingsLink_Click" Content="Open local AI settings" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock
                    FontWeight="SemiBold"
                    Opacity="0.75"
                    Text="ABOUT" />
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock
                            x:Name="VersionText"
                            Opacity="0.8" />
                        <HyperlinkButton Click="AboutLink_Click" Content="View app details" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
