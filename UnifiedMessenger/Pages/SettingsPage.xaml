<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="UnifiedMessenger.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UnifiedMessenger.Pages"
    xmlns:shared="using:UnifiedMessenger.Controls.Shared"
    xmlns:vm="using:UnifiedMessenger.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,24" ColumnSpacing="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ListView
            x:Name="SectionNavList"
            Grid.Column="0"
            AutomationProperties.Name="Settings sections"
            TabIndex="10"
            VerticalAlignment="Top"
            IsItemClickEnabled="True"
            SelectionMode="Single"
            ItemClick="SectionNavList_ItemClick">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:SettingsSectionNavItemViewModel">
                    <TextBlock Padding="8,6" Text="{x:Bind Label}" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <ScrollViewer
            x:Name="SettingsScrollViewer"
            Grid.Column="1"
            TabIndex="20"
            VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20" MaxWidth="720">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" AutomationProperties.Name="Settings" Text="Settings" />
            <TextBlock
                FontSize="12"
                Opacity="0.65"
                Text="Local AI and About open from the navigation list on the left."
                TextWrapping="WrapWholeWords" />

            <StackPanel x:Name="NotificationsSection" Tag="notifications" Spacing="8">
                <shared:SectionHeaderView Title="NOTIFICATIONS" />
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <ToggleSwitch
                            x:Name="BackgroundToastsToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="BackgroundToastsToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Background toast notifications" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="Show Windows toasts when the app is minimized or in the background."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="TaskbarBadgeToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="TaskbarBadgeToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Taskbar badge" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="Show unread count on the taskbar icon."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ComboBox
                            x:Name="PanelAutoOpenBox"
                            Header="Auto-open notification panel"
                            SelectionChanged="PanelAutoOpenBox_SelectionChanged" />

                        <ComboBox
                            x:Name="ToastSoundBox"
                            Header="Toast sound"
                            SelectionChanged="ToastSoundBox_SelectionChanged" />

                        <ToggleSwitch
                            x:Name="IncludeMutedBadgesToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="IncludeMutedBadgesToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Include muted chats in badge counts" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="When off, muted WhatsApp/Telegram chats are excluded from sidebar badges."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="ToastGroupToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="ToastGroupToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Group toasts by instance" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="Stack Windows toasts per account instead of per message."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="ToastBrandingToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="ToastBrandingToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Platform branding in toasts" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="Use instance display name as the toast header line."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <Button
                            x:Name="ClearNotificationsButton"
                            HorizontalAlignment="Left"
                            Click="ClearNotificationsButton_Click"
                            Content="Clear notification history" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel x:Name="AppearanceSection" Tag="appearance" Spacing="8">
                <shared:SectionHeaderView Title="APPEARANCE" />
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <ComboBox
                            x:Name="ThemePreferenceBox"
                            Header="App theme"
                            SelectionChanged="ThemePreferenceBox_SelectionChanged" />

                        <ComboBox
                            x:Name="PanelDockBox"
                            Header="Notification panel dock"
                            SelectionChanged="PanelDockBox_SelectionChanged" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel x:Name="SessionPerformanceSection" Tag="session-performance" Spacing="8">
                <shared:SectionHeaderView Title="SESSION &amp; PERFORMANCE" />
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <ComboBox
                            x:Name="StartupWarmModeBox"
                            Header="Startup warm mode"
                            SelectionChanged="StartupWarmModeBox_SelectionChanged" />

                        <NumberBox
                            x:Name="MaxConcurrentWebViewsBox"
                            Header="Max concurrent WebViews (0 = unlimited)"
                            Maximum="32"
                            Minimum="0"
                            SpinButtonPlacementMode="Inline"
                            ValueChanged="MaxConcurrentWebViewsBox_ValueChanged" />

                        <Button
                            x:Name="RefreshAllWebViewsButton"
                            HorizontalAlignment="Left"
                            Click="RefreshAllWebViewsButton_Click"
                            Content="Refresh all WebViews" />

                        <Expander
                            x:Name="ExperimentalExpander"
                            Header="Experimental"
                            IsExpanded="False">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    FontSize="12"
                                    Opacity="0.65"
                                    Text="Path C session options. Behavior may change in future releases."
                                    TextWrapping="WrapWholeWords" />

                        <ToggleSwitch
                            x:Name="EnableLazyWebViewLoadingToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="EnableLazyWebViewLoadingToggle_Toggled">
                            <ToggleSwitch.Header>
                                <TextBlock Text="Enable lazy WebView loading" />
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="EnablePerInstanceSleepUnloadToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="EnablePerInstanceSleepUnloadToggle_Toggled">
                            <ToggleSwitch.Header>
                                <TextBlock Text="Enable per-instance sleep unload" />
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="EnableEditInstanceMetadataToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="EnableEditInstanceMetadataToggle_Toggled">
                            <ToggleSwitch.Header>
                                <TextBlock Text="Enable edit instance metadata" />
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="EnableImportExportInstancesToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="EnableImportExportInstancesToggle_Toggled">
                            <ToggleSwitch.Header>
                                <TextBlock Text="Enable import / export instances" />
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="EnableInstanceNotesTagsToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="EnableInstanceNotesTagsToggle_Toggled">
                            <ToggleSwitch.Header>
                                <TextBlock Text="Enable instance notes and tags" />
                            </ToggleSwitch.Header>
                        </ToggleSwitch>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel x:Name="PlatformModulesSection" Tag="platform-modules" Spacing="8">
                <shared:SectionHeaderView Title="PLATFORM MODULES" />
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock
                            FontSize="12"
                            Opacity="0.65"
                            Text="Enable or disable communication adapters. Disabled platforms stop script injection, scraping, and background processing. Existing instances remain in the sidebar but run without adapter features."
                            TextWrapping="WrapWholeWords" />
                        <ListView
                            x:Name="PlatformModulesList"
                            SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:PlatformModuleToggleRowViewModel">
                                    <Grid Padding="0,4" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="2">
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind DisplayName}" />
                                            <TextBlock
                                                FontSize="11"
                                                Opacity="0.55"
                                                Text="{x:Bind CapabilitySummary}"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                        <ToggleSwitch
                                            Grid.Column="1"
                                            HorizontalAlignment="Right"
                                            IsEnabled="{x:Bind CanDisable}"
                                            IsOn="{x:Bind IsEnabled, Mode=TwoWay}"
                                            OffContent="Off"
                                            OnContent="On"
                                            Toggled="PlatformModuleToggle_Toggled"
                                            Tag="{x:Bind PlatformId}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel x:Name="ProfessionalMetricsSection" Tag="professional-metrics" Spacing="8">
                <shared:SectionHeaderView Title="PROFESSIONAL METRICS" />
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <NumberBox
                            x:Name="SlaThresholdBox"
                            Header="SLA response threshold (minutes)"
                            Maximum="120"
                            Minimum="5"
                            SpinButtonPlacementMode="Inline"
                            ValueChanged="SlaThresholdBox_ValueChanged" />
                        <TextBlock
                            FontSize="12"
                            Opacity="0.65"
                            Text="Replies slower than this count as SLA breaches on the Operations Command Center."
                            TextWrapping="WrapWholeWords" />

                        <NumberBox
                            x:Name="DashboardUrgencyThresholdBox"
                            Header="Dashboard urgency threshold"
                            Minimum="15"
                            Maximum="50"
                            SpinButtonPlacementMode="Inline"
                            ValueChanged="DashboardUrgencyThresholdBox_ValueChanged">
                            <NumberBox.Description>
                                <TextBlock
                                    Text="Minimum urgency score (15–50) for the professional urgent triage queue."
                                    TextWrapping="WrapWholeWords" />
                            </NumberBox.Description>
                        </NumberBox>

                        <ToggleSwitch
                            x:Name="EnableStartupBackfillToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="EnableStartupBackfillToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Enable startup backfill" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="After connect, reconcile unread professional inbox state for triage and dashboard KPIs without replaying notification toasts."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="ShowHeuristicExecutiveInsightsToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="ShowHeuristicExecutiveInsightsToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Show heuristic Executive Insights" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="Display compact insight cards from heuristic triage when Local AI extraction is unavailable."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <TextBlock
                            Margin="0,8,0,0"
                            FontWeight="SemiBold"
                            Text="Branch service catalog" />
                        <TextBlock
                            FontSize="12"
                            Opacity="0.65"
                            Text="Services and packages injected into WhatsApp triage prompts per branch. Use comma-separated values."
                            TextWrapping="WrapWholeWords" />
                        <ListView
                            x:Name="BranchOperationalCatalogList"
                            SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:BranchOperationalCatalogRowViewModel">
                                    <Border
                                        Margin="0,0,0,8"
                                        Padding="12"
                                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                        <StackPanel Spacing="8">
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind BranchKey}" />
                                            <TextBox
                                                Header="Services"
                                                LostFocus="BranchCatalogField_LostFocus"
                                                PlaceholderText="Comma-separated services"
                                                Tag="{x:Bind BranchKey}"
                                                Text="{x:Bind ServicesText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                            <TextBox
                                                Header="Standard packages"
                                                LostFocus="BranchCatalogField_LostFocus"
                                                PlaceholderText="Comma-separated packages"
                                                Tag="{x:Bind BranchKey}"
                                                Text="{x:Bind StandardPackagesText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                            <TextBox
                                                AcceptsReturn="True"
                                                Header="Booking rules"
                                                LostFocus="BranchCatalogField_LostFocus"
                                                PlaceholderText="Booking and deposit rules for this branch"
                                                Tag="{x:Bind BranchKey}"
                                                Text="{x:Bind BookingRulesText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel x:Name="DataPrivacySection" Tag="data-privacy" Spacing="8">
                <shared:SectionHeaderView Title="DATA &amp; PRIVACY" />
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock
                            FontSize="12"
                            Opacity="0.65"
                            Text="Destructive actions clear local operational telemetry stored on this device."
                            TextWrapping="WrapWholeWords" />
                        <Button
                            x:Name="ClearAnalyticsButton"
                            HorizontalAlignment="Left"
                            Click="ClearAnalyticsButton_Click"
                            Content="Clear operational data" />

                        <StackPanel
                            x:Name="ImportExportPanel"
                            Spacing="8"
                            Visibility="Collapsed">
                            <Button
                                x:Name="ExportInstancesButton"
                                HorizontalAlignment="Left"
                                Click="ExportInstancesButton_Click"
                                Content="Export instances.json" />
                            <CheckBox
                                x:Name="ImportBackupCheckBox"
                                Content="Create backup before import"
                                IsChecked="True" />
                            <Button
                                x:Name="ImportInstancesButton"
                                HorizontalAlignment="Left"
                                Click="ImportInstancesButton_Click"
                                Content="Import instances.json" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel x:Name="SystemSection" Tag="system" Spacing="8">
                <shared:SectionHeaderView Title="SYSTEM" />
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="Keyboard shortcuts" />
                        <TextBlock FontSize="12" Opacity="0.75" Text="Ctrl+D Dashboard · Ctrl+, Settings · Ctrl+K Command palette" />
                        <TextBlock FontSize="12" Opacity="0.75" Text="Ctrl+Shift+N Notification panel · Ctrl+1–9 Switch instance · Ctrl+Space AI copilot (when enabled)" />
                    </StackPanel>
                </Border>
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <ToggleSwitch
                            x:Name="RunInBackgroundOnCloseToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="RunInBackgroundOnCloseToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Run in background when closing" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="Hide to the system tray instead of quitting. Use tray Quit to exit fully."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="LaunchAtStartupToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="LaunchAtStartupToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Launch at startup" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="Start Unified Messenger when you sign in to Windows."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="PromptPinToTaskbarToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="PromptPinToTaskbarToggle_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Suggest pin to taskbar" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.65"
                                        Text="Show a one-time prompt to pin Unified Messenger to the taskbar."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="EnableAutoUpdateToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="EnableAutoUpdateToggle_Toggled">
                            <ToggleSwitch.Header>
                                <TextBlock Text="Enable automatic updates" />
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <ToggleSwitch
                            x:Name="PromptBeforeAutoUpdateToggle"
                            OffContent="Off"
                            OnContent="On"
                            Toggled="PromptBeforeAutoUpdateToggle_Toggled">
                            <ToggleSwitch.Header>
                                <TextBlock Text="Prompt before auto-update installs" />
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <Button
                            x:Name="CheckForUpdatesButton"
                            HorizontalAlignment="Left"
                            Click="CheckForUpdatesButton_Click"
                            Content="Check for updates" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel x:Name="RemovedAccountsSection" Tag="removed-accounts" Spacing="8">
                <shared:SectionHeaderView Title="REMOVED ACCOUNTS" />
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock
                            FontSize="12"
                            Opacity="0.65"
                            Text="Accounts removed from the sidebar keep their login session on disk and can be restored here."
                            TextWrapping="WrapWholeWords" />
                        <ListView
                            x:Name="ArchivedAccountsList"
                            SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:ArchivedAccountRowViewModel">
                                    <Grid Padding="4,8" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon
                                            VerticalAlignment="Center"
                                            FontSize="16"
                                            Glyph="{x:Bind IconGlyph}" />
                                        <StackPanel
                                            Grid.Column="1"
                                            Spacing="2"
                                            VerticalAlignment="Center">
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind DisplayName}" />
                                            <TextBlock
                                                FontSize="12"
                                                Opacity="0.65"
                                                Text="{x:Bind PlatformLabel}" />
                                            <TextBlock
                                                FontSize="11"
                                                Opacity="0.55"
                                                Text="{x:Bind ProfileLine}" />
                                        </StackPanel>
                                        <StackPanel
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                            <Button
                                                Click="RestoreAccountButton_Click"
                                                Content="Restore"
                                                Tag="{x:Bind InstanceId}" />
                                            <Button
                                                Click="PermanentDeleteAccountButton_Click"
                                                Content="Delete permanently"
                                                Tag="{x:Bind InstanceId}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <TextBlock
                            x:Name="NoArchivedAccountsText"
                            Opacity="0.55"
                            Text="No removed accounts."
                            Visibility="Collapsed" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel x:Name="StorageSection" Tag="storage" Spacing="8">
                <shared:SectionHeaderView Title="STORAGE" />
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock
                            FontSize="12"
                            Opacity="0.65"
                            Text="Instance registry" />
                        <TextBlock
                            x:Name="InstancesPathText"
                            IsTextSelectionEnabled="True"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontSize="12"
                            Opacity="0.65"
                            Text="WebView profiles" />
                        <TextBlock
                            x:Name="ProfilesPathText"
                            IsTextSelectionEnabled="True"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel x:Name="LocalAiSection" Tag="local-ai" Spacing="8">
                <shared:SectionHeaderView Title="LOCAL AI" />
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock
                            FontSize="12"
                            Opacity="0.65"
                            Text="Configure Ollama, download models, and choose the default drafting model."
                            TextWrapping="WrapWholeWords" />
                        <TextBlock
                            FontSize="12"
                            Opacity="0.65"
                            Text="Select Local AI in the settings navigation list to open the full configuration page."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel x:Name="AboutSection" Tag="about" Spacing="8">
                <shared:SectionHeaderView Title="ABOUT" />
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock
                            x:Name="VersionText"
                            Opacity="0.8" />
                        <TextBlock
                            FontSize="12"
                            Opacity="0.65"
                            Text="Select About in the settings navigation list to view version details and credits."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
