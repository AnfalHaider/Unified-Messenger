<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="UnifiedMessenger.Pages.WorkQueuePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:UnifiedMessenger.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:DataType="local:WorkQueuePage"
    xmlns:local="using:UnifiedMessenger.Pages">

    <Grid Padding="24,20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <Grid ColumnSpacing="{StaticResource UmSpacingMd}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" MinWidth="0" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    AutomationProperties.Name="Work Queue"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Text="Work Queue"
                    VerticalAlignment="Center" />
                <StackPanel
                    x:Name="OccStatusRow"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="{StaticResource UmSpacingSm}"
                    VerticalAlignment="Center"
                    Visibility="Collapsed">
                    <TextBlock
                        x:Name="LastRefreshedText"
                        Style="{StaticResource UmCaptionTextStyle}" />
                    <TextBlock
                        x:Name="OccStatusSeparator"
                        Style="{StaticResource UmCaptionTextStyle}"
                        Text="·"
                        Visibility="Collapsed" />
                    <StackPanel
                        x:Name="BackfillStatusPanel"
                        Orientation="Horizontal"
                        Spacing="6"
                        Visibility="Collapsed">
                        <ProgressRing
                            Width="14"
                            Height="14"
                            Foreground="{StaticResource UmBrandTealBrush}"
                            IsActive="True" />
                        <TextBlock
                            x:Name="BackfillStatusText"
                            FontSize="11"
                            Foreground="{StaticResource UmBrandTealDarkBrush}"
                            MaxWidth="280"
                            Opacity="0.9"
                            Style="{StaticResource UmEllipsisTextStyle}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
            <TextBlock
                Opacity="0.7"
                Text="Operations Command Center — triage, kanban, and SLA tracking for professional inboxes"
                TextWrapping="WrapWholeWords" />
        </StackPanel>

        <controls:OperationsCommandCenter
            x:Name="OccPanel"
            Grid.Row="1" />
    </Grid>
</Page>
