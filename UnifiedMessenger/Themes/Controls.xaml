<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="DashboardMetricCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource UmCornerRadiusMdValue}" />
    </Style>

    <Style x:Key="DashboardCardStyle" TargetType="Border">
        <Setter Property="Padding" Value="{StaticResource UmPaddingMd}" />
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource UmCornerRadiusMdValue}" />
    </Style>

    <Style x:Key="UmSurfaceCardStyle" TargetType="Border">
        <Setter Property="Padding" Value="{StaticResource UmPaddingLg}" />
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource UmCornerRadiusMdValue}" />
    </Style>

    <Style x:Key="SubtleButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource UmCornerRadiusMdValue}" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
    </Style>

    <Style x:Key="AccentButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource UmBrandTealBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource UmCornerRadiusMdValue}" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
    </Style>

    <Style x:Key="KanbanColumnDropZoneStyle" TargetType="Border">
        <Setter Property="MinHeight" Value="{StaticResource UmKanbanColumnMinHeight}" />
        <Setter Property="Padding" Value="{StaticResource UmPaddingKanbanColumn}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource UmCornerRadiusSmValue}" />
    </Style>

    <Style x:Key="UmTagBadgeStyle" TargetType="Border">
        <Setter Property="Padding" Value="{StaticResource UmPaddingBadge}" />
        <Setter Property="CornerRadius" Value="{StaticResource UmCornerRadiusSmValue}" />
        <Setter Property="Background" Value="{ThemeResource LayerFillColorAltBrush}" />
    </Style>

    <Style x:Key="UmSemanticBadgeStyle" TargetType="Border">
        <Setter Property="Padding" Value="{StaticResource UmPaddingBadge}" />
        <Setter Property="CornerRadius" Value="{StaticResource UmCornerRadiusSmValue}" />
    </Style>

    <Style x:Key="UmKanbanEmptyStateStyle" TargetType="Border">
        <Setter Property="Padding" Value="{StaticResource UmPaddingMd}" />
        <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource UmCornerRadiusSmValue}" />
    </Style>
</ResourceDictionary>
