<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- High-contrast overrides: system HC mode merges this dictionary at runtime. -->
    <Color x:Key="UmBrandSlateColor">#FFFFFF</Color>
    <Color x:Key="UmBrandTealColor">#FFFF00</Color>
    <Color x:Key="UmBrandTealDarkColor">#FFFF00</Color>
    <Color x:Key="UmBrandBlueColor">#FFFF00</Color>
    <Color x:Key="UmBrandBlueStartColor">#FFFF00</Color>
    <Color x:Key="UmBrandBlueEndColor">#FFFF00</Color>
    <Color x:Key="UmBrandVioletColor">#FFFF00</Color>

    <SolidColorBrush x:Key="UmBrandSlateBrush" Color="{StaticResource UmBrandSlateColor}" />
    <SolidColorBrush x:Key="UmBrandTealBrush" Color="{StaticResource UmBrandTealColor}" />
    <SolidColorBrush x:Key="UmBrandTealDarkBrush" Color="{StaticResource UmBrandTealDarkColor}" />
    <SolidColorBrush x:Key="UmBrandBlueBrush" Color="{StaticResource UmBrandBlueColor}" />
    <SolidColorBrush x:Key="UmBrandBlueStartBrush" Color="{StaticResource UmBrandBlueStartColor}" />
    <SolidColorBrush x:Key="UmBrandBlueEndBrush" Color="{StaticResource UmBrandBlueEndColor}" />
    <SolidColorBrush x:Key="UmBrandVioletBrush" Color="{StaticResource UmBrandVioletColor}" />

    <x:Double x:Key="UmOpacityMuted">1.0</x:Double>
    <x:Double x:Key="UmOpacityHint">1.0</x:Double>
    <x:Double x:Key="UmOpacitySubtle">1.0</x:Double>

    <Color x:Key="UmStatusSuccessColor">#00FF00</Color>
    <Color x:Key="UmStatusWarningColor">#FFFF00</Color>
    <Color x:Key="UmStatusDangerColor">#FF0000</Color>
    <Color x:Key="UmStatusNeutralColor">#FFFFFF</Color>
    <Color x:Key="UmStatusMutedColor">#C0C0C0</Color>
    <Color x:Key="UmStatusReadColor">#00FFFF</Color>
    <Color x:Key="UmStatusDeliveredColor">#FFFFFF</Color>
    <Color x:Key="UmStatusSentColor">#C0C0C0</Color>
    <Color x:Key="UmStatusPendingColor">#C0C0C0</Color>

    <SolidColorBrush x:Key="UmStatusSuccessBrush" Color="{StaticResource UmStatusSuccessColor}" />
    <SolidColorBrush x:Key="UmStatusWarningBrush" Color="{StaticResource UmStatusWarningColor}" />
    <SolidColorBrush x:Key="UmStatusDangerBrush" Color="{StaticResource UmStatusDangerColor}" />
    <SolidColorBrush x:Key="UmStatusNeutralBrush" Color="{StaticResource UmStatusNeutralColor}" />
    <SolidColorBrush x:Key="UmStatusMutedBrush" Color="{StaticResource UmStatusMutedColor}" />
    <SolidColorBrush x:Key="UmStatusReadBrush" Color="{StaticResource UmStatusReadColor}" />
    <SolidColorBrush x:Key="UmStatusDeliveredBrush" Color="{StaticResource UmStatusDeliveredColor}" />
    <SolidColorBrush x:Key="UmStatusSentBrush" Color="{StaticResource UmStatusSentColor}" />
    <SolidColorBrush x:Key="UmStatusPendingBrush" Color="{StaticResource UmStatusPendingColor}" />
</ResourceDictionary>
