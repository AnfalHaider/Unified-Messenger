<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="UmBrandSlateColor">#1E293B</Color>
    <Color x:Key="UmBrandBlueStartColor">#1B75BB</Color>
    <Color x:Key="UmBrandBlueEndColor">#2E3191</Color>
    <Color x:Key="UmBrandTealColor">#1B75BB</Color>
    <Color x:Key="UmBrandTealDarkColor">#2E3191</Color>
    <Color x:Key="UmBrandBlueColor">#1B75BB</Color>
    <Color x:Key="UmBrandVioletColor">#2E3191</Color>

    <SolidColorBrush x:Key="UmBrandSlateBrush" Color="{StaticResource UmBrandSlateColor}" />
    <SolidColorBrush x:Key="UmBrandBlueStartBrush" Color="{StaticResource UmBrandBlueStartColor}" />
    <SolidColorBrush x:Key="UmBrandBlueEndBrush" Color="{StaticResource UmBrandBlueEndColor}" />
    <SolidColorBrush x:Key="UmBrandTealBrush" Color="{StaticResource UmBrandTealColor}" />
    <SolidColorBrush x:Key="UmBrandTealDarkBrush" Color="{StaticResource UmBrandTealDarkColor}" />
    <SolidColorBrush x:Key="UmBrandBlueBrush" Color="{StaticResource UmBrandBlueColor}" />
    <SolidColorBrush x:Key="UmBrandVioletBrush" Color="{StaticResource UmBrandVioletColor}" />

    <x:Double x:Key="UmSpacingXs">4</x:Double>
    <x:Double x:Key="UmSpacingSm">8</x:Double>
    <x:Double x:Key="UmSpacingMd">12</x:Double>
    <x:Double x:Key="UmSpacingLg">16</x:Double>
    <x:Double x:Key="UmSpacingXl">24</x:Double>
    <x:Double x:Key="UmCornerRadiusMd">8</x:Double>
    <x:Double x:Key="UmCornerRadiusSm">6</x:Double>

    <x:Double x:Key="UmFontSizeCaption">10</x:Double>
    <x:Double x:Key="UmFontSizeSectionLabel">11</x:Double>
    <x:Double x:Key="UmFontSizeBody">12</x:Double>
    <x:Double x:Key="UmFontSizeScope">14</x:Double>
    <x:Double x:Key="UmFontSizeMetricValue">20</x:Double>
    <x:Double x:Key="UmChartHeight">110</x:Double>
    <x:Double x:Key="UmChartPlotHeight">96</x:Double>
    <x:Double x:Key="UmIconSizeSm">14</x:Double>
    <x:Double x:Key="UmKanbanColumnMinHeight">120</x:Double>
    <x:Double x:Key="UmOpacityMuted">0.65</x:Double>
    <x:Double x:Key="UmOpacityHint">0.75</x:Double>
    <x:Double x:Key="UmOpacitySubtle">0.55</x:Double>

    <Thickness x:Key="UmPaddingMd">12</Thickness>
    <Thickness x:Key="UmMetricCardPadding">12,8</Thickness>
    <Thickness x:Key="UmMarginSectionHeader">4,14,4,6</Thickness>
    <Thickness x:Key="UmMarginBrandHeader">4,0,4,12</Thickness>
    <Thickness x:Key="UmMarginIconLabelGap">10,0,0,0</Thickness>
    <Thickness x:Key="UmMarginBadgeGap">8,0,0,0</Thickness>
    <Thickness x:Key="UmPaddingLg">16</Thickness>
    <Thickness x:Key="UmPaddingSm">8</Thickness>
    <Thickness x:Key="UmPaddingFooter">12,10,12,12</Thickness>
    <Thickness x:Key="UmPaddingSidebarMenu">8,12,8,8</Thickness>
    <Thickness x:Key="UmPaddingSidebarMenuCompact">6,12,6,8</Thickness>
    <Thickness x:Key="UmPaddingFooterCompact">8,10,8,12</Thickness>
    <Color x:Key="UmModalOverlayColor">#66000000</Color>
    <SolidColorBrush x:Key="UmModalOverlayBrush" Color="{StaticResource UmModalOverlayColor}" />
    <Thickness x:Key="UmPaddingBottomXl">0,0,0,24</Thickness>
    <Thickness x:Key="UmMarginBottomSm">0,0,0,8</Thickness>
    <CornerRadius x:Key="UmCornerRadiusMdValue">8</CornerRadius>
    <CornerRadius x:Key="UmCornerRadiusSmValue">6</CornerRadius>
</ResourceDictionary>
