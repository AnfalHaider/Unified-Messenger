<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="UmBrandSlateColor">#1E293B</Color>
    <Color x:Key="UmBrandBlueStartColor">#1B75BB</Color>
    <Color x:Key="UmBrandBlueEndColor">#2E3191</Color>
    <Color x:Key="UmBrandTealColor">#1B75BB</Color>
    <Color x:Key="UmBrandTealDarkColor">#2E3191</Color>
    <Color x:Key="UmBrandBlueColor">#1B75BB</Color>
    <Color x:Key="UmBrandVioletColor">#2E3191</Color>

    <SolidColorBrush x:Key="UmBrandSlateBrush" Color="{StaticResource UmBrandSlateColor}" />
    <SolidColorBrush x:Key="UmBrandBlueStartBrush" Color="{StaticResource UmBrandBlueStartColor}" />
    <SolidColorBrush x:Key="UmBrandBlueEndBrush" Color="{StaticResource UmBrandBlueEndColor}" />
    <SolidColorBrush x:Key="UmBrandTealBrush" Color="{StaticResource UmBrandTealColor}" />
    <SolidColorBrush x:Key="UmBrandTealDarkBrush" Color="{StaticResource UmBrandTealDarkColor}" />
    <SolidColorBrush x:Key="UmBrandBlueBrush" Color="{StaticResource UmBrandBlueColor}" />
    <SolidColorBrush x:Key="UmBrandVioletBrush" Color="{StaticResource UmBrandVioletColor}" />

    <x:Double x:Key="UmSpacingXs">4</x:Double>
    <x:Double x:Key="UmSpacingSm">8</x:Double>
    <x:Double x:Key="UmSpacingMd">12</x:Double>
    <x:Double x:Key="UmSpacingLg">16</x:Double>
    <x:Double x:Key="UmSpacingXl">24</x:Double>
    <x:Double x:Key="UmCornerRadiusMd">8</x:Double>

    <Thickness x:Key="UmPaddingMd">12</Thickness>
    <Thickness x:Key="UmPaddingLg">16</Thickness>
    <CornerRadius x:Key="UmCornerRadiusMdValue">8</CornerRadius>
</ResourceDictionary>
